@page "/Admin/Orders"
@rendermode InteractiveServer
@using FishCoinBlazorApp.Services.Admin
@inject AdminOrderService OrderService
@inject IJSRuntime JsRuntime

<Topbar Title="შეკვეთების მართვა" />

<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h4 class="card-title">შეკვეთების ისტორია</h4>
                
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <div class="search-box">
                        <input type="text" class="form-control form-control-sm" placeholder="ძებნა (Order #)..." @bind="SearchText" @bind:event="oninput" />
                    </div>

                    <select class="form-select form-select-sm w-auto" @onchange="OnStatusFilterChanged">
                        <option value="">ყველა სტატუსი</option>
                        <option value="Pending">🕒 Pending</option>
                        <option value="Paid">✅ Paid</option>
                        <option value="Cancelled">❌ Cancelled</option>
                    </select>

                    <select class="form-select form-select-sm w-auto" @onchange="OnPaymentFilterChanged">
                        <option value="">გადახდის ტიპი</option>
                        <option value="Cash">💵 თანხა</option>
                        <option value="Points">🪙 ქულები</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="bg-light-subtle">
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>ორდერის #</th>
                            <th>თარიღი</th>
                            <th>მომხმარებელი</th>
                            <th>სტატუსი</th>
                            <th>გადახდის მეთოდი</th>
                            <th>სულ ჯამი</th>
                            <th>დარიცხული ქულები</th>
                            <th>მოქმედება</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Orders != null)
                        {
                            @foreach (var order in Orders)
                            {
                                <tr>
                                    <td>
                                        <button class="btn btn-sm btn-light" @onclick="() => ToggleOrderDetails(order.Id)">
                                            <iconify-icon icon="@(ExpandedOrderId == order.Id ? "solar:alt-arrow-up-broken" : "solar:alt-arrow-down-broken")"></iconify-icon>
                                        </button>
                                    </td>
                                    <td class="fw-bold">@order.OrderNumber</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span>@order.FirstNameAndLastName</span>
                                            <small class="text-muted">@order.PhoneNumber</small>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusClass(order.Status.ToString())">@order.Status</span>
                                    </td>
                                    <td>
                                        @if (order.OrderItems.Any(x => x.PointsPriceAtPurchase > 0))
                                        {
                                            <span class="badge bg-info-subtle text-info">გადახდა: ქულები</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success">გადახდა: თანხა</span>
                                        }
                                    </td>
                                    <td class="fw-bold text-dark">
                                        @if (order.TotalAmountPoints > 0)
                                        {
                                            <span>@order.TotalAmountPoints <i class="bx bxs-coin-stack text-warning"></i></span>
                                        }
                                        else
                                        {
                                            <span>₾@order.TotalAmountGEL</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="text-primary fw-medium">+@order.PointsEarned</span>
                                            <iconify-icon icon="solar:stars-minimalistic-bold-duotone" class="text-primary fs-18"></iconify-icon>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-soft-primary btn-sm" @onclick="() => OpenEditModal(order)">
                                                <iconify-icon icon="solar:pen-new-square-broken"></iconify-icon>
                                            </button>
                                            <button class="btn btn-soft-danger btn-sm">
                                                <iconify-icon icon="solar:trash-bin-trash-broken"></iconify-icon>
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                @if (ExpandedOrderId == order.Id)
                                {
                                    <tr class="bg-transparent">
                                        <td colspan="9">
                                            <div class="p-3 border rounded bg-body m-2 shadow-sm text-body">
                                                <h5 class="mb-3">პროდუქტების ჩამონათვალი</h5>
                                                <table class="table table-sm table-bordered align-middle text-body">
                                                    <thead class="table-light-subtle">
                                                        <tr>
                                                            <th>პროდუქტის ID</th>
                                                            <th>რაოდენობა</th>
                                                            <th>ერთეულის ფასი</th>
                                                            <th>ჯამი</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in order.OrderItems)
                                                        {
                                                            <tr>
                                                                <td>#@item.ProductId</td>
                                                                <td>@item.Quantity ცალი</td>
                                                                <td>
                                                                    @if (item.PointsPriceAtPurchase > 0)
                                                                    {
                                                                        <span>@item.PointsPriceAtPurchase ქულა</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>₾@item.PriceAtPurchase</span>
                                                                    }
                                                                </td>
                                                                <td class="fw-medium">
                                                                    @(item.PointsPriceAtPurchase > 0
                                                                        ? (item.PointsPriceAtPurchase * item.Quantity) + " ქულა"
                                                                        : "₾" + (item.PriceAtPurchase * item.Quantity))
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                                <div class="mt-2 small opacity-75">
                                                    <strong>მისამართი:</strong> @order.ShippingAddress |
                                                    <strong>მიტანის საფასური:</strong> ₾@order.DeliveryFee
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-footer border-top">
                <nav>
                    <ul class="pagination justify-content-end mb-0">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" @onclick="() => ChangePage(CurrentPage - 1)" style="cursor:pointer">წინა</a>
                        </li>
                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var p = i;
                            <li class="page-item @(CurrentPage == p ? "active" : "")">
                                <a class="page-link" @onclick="() => ChangePage(p)" style="cursor:pointer">@p</a>
                            </li>
                        }
                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <a class="page-link" @onclick="() => ChangePage(CurrentPage + 1)" style="cursor:pointer">შემდეგი</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@* სტატუსის რედაქტირების მოდალი *@
@if (ShowEditModal && SelectedOrder != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title text-white">შეკვეთის მართვა - @SelectedOrder.OrderNumber</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="p-2 bg-light rounded shadow-sm border">
                                <p class="mb-1"><strong>მომხმარებელი:</strong> @SelectedOrder.FirstNameAndLastName</p>
                                <p class="mb-1"><strong>თარიღი:</strong> @SelectedOrder.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                                <hr class="my-2" />
                                <p class="mb-1 text-primary">
                                    <strong>გადახდის მეთოდი:</strong>
                                    @(SelectedOrder.OrderItems.Any(x => x.PointsPriceAtPurchase > 0) ? "ქულებით გადახდა" : "ფულადი ანგარიშსწორება")
                                </p>
                                <p class="mb-1 fw-bold text-dark">
                                    <strong>ჯამური ღირებულება:</strong>
                                    @if (SelectedOrder.TotalAmountPoints > 0)
                                    {
                                        <span>@SelectedOrder.TotalAmountPoints <i class="bx bxs-coin-stack text-warning"></i></span>
                                    }
                                    else
                                    {
                                        <span>₾@SelectedOrder.TotalAmountGEL</span>
                                    }
                                </p>
                                <p class="mb-0 text-success">
                                    <strong>დაგროვილი ქულები:</strong> +@SelectedOrder.PointsEarned <iconify-icon icon="solar:stars-minimalistic-bold-duotone"></iconify-icon>
                                </p>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-medium">შეცვალეთ სტატუსი:</label>
                            <select class="form-select shadow-none border-primary" @bind="NewStatus">
                                <option value="Pending">🕒 Pending</option>
                                <option value="Paid">✅ Paid</option>
                                <option value="Cancelled">❌ Cancelled</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">დახურვა</button>
                    <button type="button" class="btn btn-primary px-4" @onclick="UpdateOrderStatus">ცვლილების შენახვა</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FishCoinBlazorApp.Entites.Product.Order> Orders;
    private string SearchTerm = "";
    private string StatusFilter = "";
    private string PaymentFilter = "";
    
    private bool ShowEditModal = false;
    private FishCoinBlazorApp.Entites.Product.Order SelectedOrder;
    private string NewStatus;

    private string SearchText
    {
        get => SearchTerm;
        set
        {
            if (SearchTerm != value)
            {
                SearchTerm = value;
                CurrentPage = 1;
                _ = LoadOrders();
            }
        }
    }

    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int PageSize = 10;
    private int? ExpandedOrderId;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        // შენი სერვისის მეთოდი უნდა იღებდეს ახალ პარამეტრებსაც, თუ არა და ფრონტზე გაფილტრავ (თუმცა პეიჯინგი არ იმუშავებს სწორად)
        var result = await OrderService.GetPagedOrdersAsync(CurrentPage, PageSize, SearchTerm);
        
        var query = result.Orders.AsQueryable();

        // ფილტრაცია სტატუსით
        if (!string.IsNullOrEmpty(StatusFilter))
        {
            query = query.Where(o => o.Status.ToString() == StatusFilter);
        }

        // ფილტრაცია გადახდის მეთოდით
        if (!string.IsNullOrEmpty(PaymentFilter))
        {
            if (PaymentFilter == "Points")
                query = query.Where(o => o.OrderItems.Any(x => x.PointsPriceAtPurchase > 0));
            else if (PaymentFilter == "Cash")
                query = query.Where(o => o.OrderItems.All(x => x.PointsPriceAtPurchase == 0));
        }

        Orders = query.ToList();
        TotalPages = result.TotalPages;
        StateHasChanged();
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        StatusFilter = e.Value?.ToString() ?? "";
        CurrentPage = 1;
        await LoadOrders();
    }

    private async Task OnPaymentFilterChanged(ChangeEventArgs e)
    {
        PaymentFilter = e.Value?.ToString() ?? "";
        CurrentPage = 1;
        await LoadOrders();
    }

    private void OpenEditModal(FishCoinBlazorApp.Entites.Product.Order order)
    {
        SelectedOrder = order;
        NewStatus = order.Status.ToString();
        ShowEditModal = true;
    }

    private void CloseModal()
    {
        ShowEditModal = false;
        SelectedOrder = null;
    }

    private async Task UpdateOrderStatus()
    {
        // აქ გამოიძახებ შენს სერვისს: მაგ. await OrderService.UpdateStatusAsync(SelectedOrder.Id, NewStatus);
        CloseModal();
        await LoadOrders();
    }

    private void ToggleOrderDetails(int orderId)
    {
        if (ExpandedOrderId == orderId)
            ExpandedOrderId = null;
        else
            ExpandedOrderId = orderId;
    }

    private async Task ChangePage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            CurrentPage = page;
            await LoadOrders();
        }
    }

    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-warning-subtle text-warning",
        "Paid" => "bg-success-subtle text-success",
        "Cancelled" => "bg-danger-subtle text-danger",
        _ => "bg-secondary-subtle text-secondary"
    };
}