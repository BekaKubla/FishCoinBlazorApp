@page "/Admin/CreateOrUpdate"
@page "/Admin/CreateOrUpdate/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@using FishCoinBlazorApp.Services.Models.Admin
@inject FishCoinBlazorApp.Services.Admin.AdminProductService AdminProductService
@inject IJSRuntime JsRuntime
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms

<Topbar Title="პროდუქტის დამატება" />

<EditForm Model="@newProduct" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="row">
        <div class="col-xl-3 col-lg-4">
            <div class="card">
                <div class="card-body">
                    <div class="bg-light text-center rounded position-relative">
                        <img src="@(string.IsNullOrEmpty(previewUrl) ? "/images/product/p-1.png" : previewUrl)"
                             alt="პროდუქტის სურათი" class="avatar-xxl">
                        
                        @if (newProduct.DiscountPrecentage > 0)
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2">-@newProduct.DiscountPrecentage%</span>
                        }
                    </div>

                    <div class="mt-3">
                        <h4 class="text-center">@(string.IsNullOrEmpty(newProduct.Name) ? "პროდუქტის დასახელება" : newProduct.Name)</h4>
                        <p class="text-muted text-center small text-truncate">@newProduct.Description</p>
                        
                        <div class="d-flex justify-content-between border-bottom pb-2 mt-3">
                            <span class="text-muted">ფასი:</span>
                            <div>
                                @if (newProduct.DiscountPrecentage > 0)
                                {
                                    <span class="text-muted text-decoration-line-through me-2" style="font-size: 0.85rem;">@newProduct.Price ₾</span>
                                    <span class="text-danger fw-bold">@DiscountedPrice ₾</span>
                                }
                                else
                                {
                                    <span class="fw-bold">@newProduct.Price ₾</span>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-between border-bottom pb-2 mt-2">
                            <span class="text-muted">სუფთა მოგება:</span>
                            <span class="text-success fw-bold">@ProfitAmount ₾</span>
                        </div>

                        <div class="bg-primary-subtle p-2 rounded mt-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="text-primary fw-medium"><i class="bx bxs-coin-stack me-1"></i>მისაღები ქულები:</small>
                                <span class="badge bg-primary">@newProduct.PointsReward</span>
                            </div>
                            
                            @if (newProduct.IsRedeemable)
                            {
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-success fw-medium"><i class="bx bxs-purchase-tag me-1"></i>ღირებულება ქულებში:</small>
                                    <span class="badge bg-success">@newProduct.PointsPrice</span>
                                </div>
                            }
                        </div>

                        <div class="row mt-3 text-center">
                            <div class="col-12 border-top pt-2">
                                <p class="mb-0 text-muted small">მარაგი: <b>@newProduct.StockQuantity ცალი</b></p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer border-top bg-transparent">
                    <div class="row g-2">
                        <div class="col-lg-6"><button type="submit" class="btn btn-primary w-100">შენახვა</button></div>
                        <div class="col-lg-6"><button type="button" class="btn btn-outline-secondary w-100" @onclick="ResetForm">გასუფთავება</button></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-9 col-lg-8">
            <div class="card">
                <div class="card-header"><h4 class="card-title">მედია და აღწერა</h4></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-12 mb-3">
                            <label class="form-label fw-bold">პროდუქტის დასახელება</label>
                            <InputText @bind-Value="newProduct.Name" class="form-control" placeholder="მაგ: Shimano Reel 4000" />
                            <ValidationMessage For="@(() => newProduct.Name)" />
                        </div>
                        <div class="col-lg-12 mb-3">
                            <label class="form-label">პროდუქტის ფოტო</label>
                            <InputFile OnChange="OnInputFileChange" class="form-control" accept=".jpg,.jpeg,.png" />
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label">აღწერა</label>
                            <InputTextArea @bind-Value="newProduct.Description" class="form-control" rows="3" placeholder="მოკლე ინფორმაცია პროდუქტზე..." />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h4 class="card-title">ფასწარმოქმნა და მოგების გაანგარიშება</h4></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-2 mb-3">
                            <label class="form-label">თვითღირებულება (₾)</label>
                            <InputNumber TValue="decimal" Value="newProduct.CostPrice"
                                         ValueExpression="() => newProduct.CostPrice"
                                         ValueChanged="OnCostPriceChanged" class="form-control" />
                        </div>

                        <div class="col-lg-2 mb-3">
                            <label class="form-label">მარჟა (%)</label>
                            <InputNumber TValue="decimal" Value="marginPercentage"
                                         ValueExpression="() => marginPercentage"
                                         ValueChanged="OnMarginChanged" class="form-control" />
                        </div>

                        <div class="col-lg-2 mb-3">
                            <label class="form-label">გასაყიდი ფასი (₾)</label>
                            <InputNumber TValue="decimal" Value="newProduct.Price"
                                         ValueExpression="() => newProduct.Price"
                                         ValueChanged="OnPriceChanged" class="form-control" />
                        </div>

                        <div class="col-lg-3 mb-3">
                            <label class="form-label">ფასდაკლება (%)</label>
                            <InputNumber TValue="decimal?" Value="newProduct.DiscountPrecentage"
                                         ValueExpression="() => newProduct.DiscountPrecentage"
                                         ValueChanged="OnDiscountChanged" class="form-control" />
                        </div>

                        <div class="col-lg-3 mb-3">
                            <label class="form-label">მოგება (₾)</label>
                            <input type="text" class="form-control fw-bold text-success" value="@ProfitAmount ₾" disabled />
                        </div>

                        <div class="col-lg-6 mb-3">
                            <label class="form-label">რაოდენობა საწყობში</label>
                            <InputNumber @bind-Value="newProduct.StockQuantity" class="form-control" />
                        </div>
                        <div class="col-lg-6 mb-3">
                            <label class="form-label">კატეგორიის ID</label>
                            <InputNumber @bind-Value="newProduct.ProductCategoryId" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h4 class="card-title">ლოიალობის სისტემა (FishCoin)</h4></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-4 mb-3">
                            <label class="form-label">ქეშბექი %</label>
                            <InputNumber TValue="decimal" Value="rewardPercentage" ValueExpression="() => rewardPercentage"
                                         ValueChanged="OnRewardPercentageChanged" class="form-control" />
                            <small class="text-primary fw-bold">დაერიცხება: @newProduct.PointsReward ქულა</small>
                        </div>
                        <div class="col-lg-4 mb-3">
                            <label class="form-label">ქულებით ყიდვა</label>
                            <div class="form-check form-switch mt-2">
                                <InputCheckbox TValue="bool" Value="newProduct.IsRedeemable" ValueExpression="() => newProduct.IsRedeemable"
                                               ValueChanged="OnIsRedeemableChanged" class="form-check-input" />
                            </div>
                        </div>
                        <div class="col-lg-4 mb-3">
                            <label class="form-label">ღირებულება ქულებში (10 თეთრი = 1ქ)</label>
                            <InputNumber @bind-Value="newProduct.PointsPrice" class="form-control" disabled="@(!newProduct.IsRedeemable)" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public int? Id { get; set; }
    private ProductModel newProduct = new();
    private IBrowserFile? selectedFile;
    private string? previewUrl;
    private decimal rewardPercentage;
    private decimal marginPercentage;

    // გამოთვლილი ფასი ფასდაკლებით
    private decimal DiscountedPrice => Math.Round(newProduct.Price * (1 - (newProduct.DiscountPrecentage ?? 0) / 100m), 2);

    // მოგების გამოთვლა (DiscountedPrice - CostPrice)
    private decimal ProfitAmount => Math.Round(DiscountedPrice - newProduct.CostPrice, 2);

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var productToEdit = await AdminProductService.GetProductById(Id.Value);
            if (productToEdit != null)
            {
                newProduct = productToEdit;
                previewUrl = newProduct.ImageUrl;
                
                if (newProduct.CostPrice > 0)
                    marginPercentage = Math.Round(((newProduct.Price - newProduct.CostPrice) / newProduct.CostPrice) * 100m, 2);
                
                if (newProduct.Price > 0)
                    rewardPercentage = Math.Round(((decimal)newProduct.PointsReward * 0.10m / DiscountedPrice) * 100m, 2);
            }
        }
    }

    private void OnCostPriceChanged(decimal value)
    {
        newProduct.CostPrice = value;
        if (newProduct.Price > 0 && newProduct.CostPrice > 0)
        {
            marginPercentage = Math.Round(((newProduct.Price - newProduct.CostPrice) / newProduct.CostPrice) * 100m, 2);
        }
        CalculateLoyalty();
    }

    private void OnMarginChanged(decimal value)
    {
        marginPercentage = value;
        if (marginPercentage > 0 && newProduct.CostPrice > 0)
        {
            newProduct.Price = Math.Round(newProduct.CostPrice + (newProduct.CostPrice * marginPercentage / 100m), 2);
        }
        CalculateLoyalty();
    }

    private void OnPriceChanged(decimal value)
    {
        newProduct.Price = value;
        if (newProduct.CostPrice > 0)
        {
            marginPercentage = Math.Round(((newProduct.Price - newProduct.CostPrice) / newProduct.CostPrice) * 100m, 2);
        }
        CalculateLoyalty();
    }

    private void OnDiscountChanged(decimal? value)
    {
        newProduct.DiscountPrecentage = value;
        // როცა ფასდაკლება იცვლება, ქულები უნდა გადაითვალოს რეალური გასაყიდი ფასიდან
        CalculateLoyalty();
    }

    private void OnRewardPercentageChanged(decimal value)
    {
        rewardPercentage = value;
        CalculateLoyalty();
    }

    private void OnIsRedeemableChanged(bool value)
    {
        newProduct.IsRedeemable = value;
        if (value)
        {
            // გამოსასყიდი ქულებიც DiscountedPrice-დან დაითვალოს
            newProduct.PointsPrice = (int)(DiscountedPrice * 10);
        }
        else
        {
            newProduct.PointsPrice = null;
        }
    }

    private void CalculateLoyalty()
    {
        // ქეშბექი ითვლება რეალური (ფასდაკლებული) გასაყიდი ფასიდან
        decimal rewardInGEL = DiscountedPrice * (rewardPercentage / 100m);
        newProduct.PointsReward = (int)(rewardInGEL / 0.10m);
        
        if (newProduct.IsRedeemable)
        {
            // თუ პროდუქტის ყიდვა ქულებით მოსულა, მისი ფასი ქულებშიც რეალურ ფასს მიყვეს
            newProduct.PointsPrice = (int)(DiscountedPrice * 10);
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        var format = "image/png";
        var resizedImage = await e.File.RequestImageFileAsync(format, 300, 300);
        var buffer = new byte[resizedImage.Size];
        await resizedImage.OpenReadStream().ReadAsync(buffer);
        previewUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (Id.HasValue)
            {
                // რედაქტირების ლოგიკა
                await AdminProductService.UpdateProduct(Id.Value, newProduct, selectedFile);
                await JsRuntime.InvokeVoidAsync("alert", "პროდუქტი წარმატებით განახლდა!");
            }
            else
            {
                // შექმნის ლოგიკა
                await AdminProductService.CreateProduct(newProduct, selectedFile);
                await JsRuntime.InvokeVoidAsync("alert", "პროდუქტი წარმატებით დაემატა!");
                ResetForm();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            await JsRuntime.InvokeVoidAsync("alert", "შეცდომა შენახვისას!");
        }
    }

    private void ResetForm()
    {
        newProduct = new ProductModel();
        rewardPercentage = 0;
        marginPercentage = 0;
        previewUrl = null;
        selectedFile = null;
    }
}