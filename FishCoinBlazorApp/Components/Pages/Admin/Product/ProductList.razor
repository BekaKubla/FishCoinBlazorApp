@page "/Admin/Product-List"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IJSRuntime JsRuntime
@using FishCoinBlazorApp.Entites.Product
@using Microsoft.AspNetCore.Authorization
@inject FishCoinBlazorApp.Services.Admin.AdminProductService AdminProductService

<Topbar Title="პროდუქტების სია" />

<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center gap-1">
                <h4 class="card-title flex-grow-1">ყველა პროდუქტი</h4>
                
                <div class="d-flex align-items-center gap-2">
                    <input type="text" class="form-control form-control-sm" placeholder="ძებნა..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                    <a href="Admin/CreateOrUpdate" class="btn btn-sm btn-primary">პროდუქტის დამატება</a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0 table-hover table-centered">
                    <thead class="bg-light-subtle">
                        <tr>
                            <th>ფოტო</th>
                            <th>დასახელება</th>
                            <th>საწყისი ფასი</th>
                            <th>ფასდაკლება</th>
                            <th>გასაყიდი ფასი</th>
                            <th>რაოდენობა</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Products != null)
                        {
                            @foreach (var product in Products)
                            {
                                <tr>
                                    <td>
                                        <div class="rounded bg-light avatar-md d-flex align-items-center justify-content-center">
                                            <img src="@product.ImageUrl" alt="" class="avatar-md">
                                        </div>
                                    </td>
                                    <td>@product.Name</td>
                                    <td>
                                        @if (product.DiscountPrecentage > 0)
                                        {
                                            <span class="text-decoration-line-through text-muted">₾@product.Price</span>
                                        }
                                        else
                                        {
                                            <span>₾@product.Price</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.DiscountPrecentage > 0)
                                        {
                                            <span class="badge bg-danger-subtle text-danger">-@product.DiscountPrecentage%</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">---</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="fw-bold text-dark">₾@CalculateDiscountedPrice(product.Price, product.DiscountPrecentage)</span>
                                    </td>
                                    <td>@product.StockQuantity</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="/Admin/CreateOrUpdate/@product.Id" class="btn btn-soft-primary btn-sm">
                                                <iconify-icon icon="solar:pen-2-broken" class="align-middle fs-18"></iconify-icon>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-footer border-top">
                <nav>
                    <ul class="pagination justify-content-end mb-0">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" @onclick="() => ChangePage(CurrentPage - 1)" style="cursor:pointer">წინა</a>
                        </li>
                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(CurrentPage == pageNumber ? "active" : "")">
                                <a class="page-link" @onclick="() => ChangePage(pageNumber)" style="cursor:pointer">@pageNumber</a>
                            </li>
                        }
                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <a class="page-link" @onclick="() => ChangePage(CurrentPage + 1)" style="cursor:pointer">შემდეგი</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Product> Products;
    private string SearchTerm = "";
    private int CurrentPage = 1;
    private int TotalPages;
    private int PageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        var result = await AdminProductService.GetPagedProductsAsync(CurrentPage, PageSize, SearchTerm);
        Products = result.Products;
        TotalPages = result.TotalPages;
    }

    private decimal CalculateDiscountedPrice(decimal price, decimal? discountPercent)
    {
        if (discountPercent == null || discountPercent <= 0)
            return price;

        return Math.Round(price * (1 - (discountPercent.Value / 100m)), 2);
    }

    private async Task HandleSearch()
    {
        CurrentPage = 1;
        await LoadProducts();
    }

    private async Task ChangePage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            CurrentPage = page;
            await LoadProducts();
        }
    }
}