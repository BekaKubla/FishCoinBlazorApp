@page "/order-success/{OrderNumber}"
@using FishCoinBlazorApp.Entites.Product
@inject FishCoinBlazorApp.Services.OrderService OrderService
@inject NavigationManager NavigationManager
@inject Services.WhatsAppService WhatsAppService
@inject IJSRuntime JsRuntime

<Topbar Title="შეკვეთა დასრულებულია" />

<div class="container mt-2 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7 col-sm-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden animated-pop-in">

                @* მწვანე მადლობის სექცია *@
                <div class="card-header bg-success bg-gradient py-3 px-4 border-0 text-center">
                    <iconify-icon icon="solar:check-circle-bold" class="text-white fs-32 mb-1"></iconify-icon>
                    <h5 class="text-white fw-bold mb-0">გმადლობთ!</h5>
                </div>

                <div class="card-body p-3">
                    @if (order == null)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        </div>
                    }
                    else
                    {
                        @* შეკვეთის ნომერი როგორც მთავარი ჰედერი შუაში *@
                        <div class="text-center mb-4 pt-2">
                            <h6 class="text-muted fs-11 text-uppercase fw-bold mb-1">შეკვეთა მიღებულია</h6>
                            <h5 class="fw-black text-dark mb-0">#@OrderNumber</h5>
                        </div>

                        @* Pickup Info Main Block *@
                        <div class="pickup-container p-3 rounded-4 mb-3 border bg-light-subtle">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <iconify-icon icon="solar:shop-bold" class="text-primary fs-20"></iconify-icon>
                                <h6 class="text-dark fw-bold mb-0 fs-14">მაღაზიაში აღება</h6>
                            </div>
                            
                            <p class="fs-12 text-muted mb-3 lh-sm">
                                🎣 შეკვეთა მზადდება. გთხოვთ გვეწვიოთ მითითებულ მისამართზე:
                            </p>

                            @* მისამართი და საათები *@
                            <div class="d-flex flex-column gap-2 mb-3">
                                <a href="https://www.google.com/maps/search/?api=1&query=Kutaisi" target="_blank" class="text-decoration-none d-flex align-items-center gap-2">
                                    <iconify-icon icon="solar:map-point-bold" class="text-danger fs-18"></iconify-icon>
                                    <span class="fs-13 fw-medium text-primary text-decoration-underline">ქუთაისი, [ზუსტი ქუჩა]</span>
                                </a>
                                <div class="d-flex align-items-center gap-2 text-muted">
                                    <iconify-icon icon="solar:clock-circle-linear" class="fs-18"></iconify-icon>
                                    <span class="fs-12">ყოველდღე: 10:00 - 20:00</span>
                                </div>
                            </div>

                            @* გაფრთხილება *@
                            <div class="bg-warning-subtle border border-warning-subtle rounded-3 p-2 d-flex align-items-start gap-2 shadow-xs">
                                <iconify-icon icon="solar:info-circle-bold" class="text-warning-emphasis fs-16 mt-1"></iconify-icon>
                                <p class="fs-11 text-dark mb-0 lh-sm">
                                    <strong>გაითვალისწინეთ:</strong> ონლაინ შეკვეთა დაგეხმარებათ დროის დაზოგვაში – მაღაზიაში ყველაფერი გამზადებული დაგხვდებათ. თუმცა, ვინაიდან პროდუქცია არ იჯავშნება და მარაგები მუდმივად იცვლება, გირჩევთ მალე გვეწვიოთ, რათა სასურველი ნივთი გაყიდული არ დაგხვდეთ.
                                </p>
                            </div>
                        </div>

                        @* მოკლე შეჯამება *@
                        <div class="d-flex justify-content-between align-items-center px-2 mb-3">
                            <span class="text-muted fs-13">გადასახდელი:</span>
                            <span class="fs-16 fw-black text-primary">@order.TotalAmountGEL.ToString("N2") ₾</span>
                        </div>

                        <div class="d-flex flex-column gap-2">
                            <a href="@WhatsAppService.GetSettlementOrderUrl(order)"
                               target="_blank"
                               class="btn btn-outline-success d-flex align-items-center justify-content-center gap-2 w-100 py-2 rounded-3 border-2">
                                <i class="bx bxl-whatsapp fs-20"></i>
                                <span class="fw-bold fs-13">ანგარიშსწორება WhatsApp-ით</span>
                            </a>

                            <button @onclick="GoHome" class="btn btn-primary py-2 rounded-3 fw-bold fs-13 shadow-sm">
                                <iconify-icon icon="solar:home-2-linear" class="me-1 align-middle"></iconify-icon>
                                მთავარი გვერდი
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-32 { font-size: 32px; }
    .fs-20 { font-size: 20px; }
    .fs-18 { font-size: 18px; }
    .fs-16 { font-size: 16px; }
    .fs-14 { font-size: 14px; }
    .fs-13 { font-size: 13px; }
    .fs-12 { font-size: 12px; }
    .fs-11 { font-size: 11px; }
    .fw-black { font-weight: 900; }
    .bg-light-subtle { background-color: #f8f9fa !important; }
    .shadow-xs { box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .animated-pop-in { animation: popIn 0.3s ease-out; }

    @@keyframes popIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public string OrderNumber { get; set; }
    private Order? order;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            order = await OrderService.GetOrderByIdAsync(OrderNumber);
            if (order == null) NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            NavigationManager.NavigateTo("/");
        }
    }

    private void GoHome() => NavigationManager.NavigateTo("/products");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
            StateHasChanged();
        }
    }
}