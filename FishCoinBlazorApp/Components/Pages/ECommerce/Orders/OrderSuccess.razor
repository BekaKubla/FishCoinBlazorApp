@page "/order-success/{OrderNumber}"
@using FishCoinBlazorApp.Entites.Product
@inject FishCoinBlazorApp.Services.OrderService OrderService
@inject NavigationManager NavigationManager
@inject Services.WhatsAppService WhatsAppService
@inject IJSRuntime JsRuntime

<Topbar Title="შეკვეთა დასრულებულია" />

<div class="container mt-2 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7 col-sm-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden animated-pop-in">

                @* კომპაქტური Header *@
                <div class="card-header bg-success bg-gradient py-3 px-4 border-0">
                    <div class="d-flex align-items-center justify-content-center gap-3">
                        <div class="success-icon-container">
                            <iconify-icon icon="solar:check-circle-bold" class="text-white fs-32"></iconify-icon>
                        </div>
                        <div class="text-start">
                            <h5 class="text-white fw-bold mb-0 lh-1">გმადლობთ!</h5>
                            <p class="text-white-50 fs-12 mb-0">შეკვეთა მიღებულია</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    @if (order == null)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-4 bg-light rounded-3 p-2 px-3 border">
                            <span class="fs-11 text-muted text-uppercase fw-bold">შეკვეთის #</span>
                            <span class="fw-bold text-dark fs-14">@order.OrderNumber</span>
                        </div>

                        @* მაღაზიაში აღების და მარაგების გაფრთხილება *@
                        <div class="pickup-info-card p-3 rounded-4 mb-4 border-start border-primary border-4 shadow-sm bg-primary-subtle">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <iconify-icon icon="solar:shop-bold" class="text-primary fs-20"></iconify-icon>
                                <h6 class="text-primary-emphasis fw-bold mb-0 fs-14">მაღაზიაში აღება </h6>
                            </div>
                            <p class="fs-12 text-dark mb-2 lh-sm">
                                🎣 თქვენი შეკვეთა უკვე გადაეცა ჩვენს გუნდს შესაფუთად. მაღაზიაში მოსვლისას ყველაფერი გამზადებული დაგხვდებათ, რაც დაგიზოგავთ დროს.
                            </p>
                            <div class="alert alert-warning py-2 px-3 mb-0 border-0 rounded-3 shadow-sm">
                                <div class="d-flex align-items-start gap-2">
                                    <iconify-icon icon="solar:danger-bold" class="text-danger mt-1"></iconify-icon>
                                    <p class="fs-11 text-danger-emphasis fw-bold mb-0 lh-sm">
                                        ყურადღება: ონლაინ შეკვეთა არ ნიშნავს ნივთების დაჯავშნას. გთხოვთ, გვეწვიოთ დროულად, სანამ პროდუქცია მარაგშია.
                                    </p>
                                </div>
                            </div>
                        </div>

                        @if (order.PointsEarned > 0)
                        {
                            <div class="points-toast d-flex flex-column gap-1 p-3 rounded-3 mb-4 bg-warning-subtle border-start border-warning border-3 shadow-sm">
                                <div class="d-flex align-items-center gap-2">
                                    <iconify-icon icon="solar:star-bold" class="text-warning fs-18"></iconify-icon>
                                    <span class="fs-14 fw-bold text-warning-emphasis">თქვენ დაგერიცხებათ @order.PointsEarned ქულა</span>
                                </div>

                                <div class="mt-2 pt-2 border-top border-warning-subtle">
                                    <p class="fs-11 text-muted mb-0 lh-sm">
                                        <iconify-icon icon="solar:info-circle-bold" class="me-1 vertical-middle"></iconify-icon>
                                        <strong>გაითვალისწინეთ:</strong> ქულები გააქტიურდება ანგარიშსწორების დასრულებისთანავე.
                                    </p>
                                </div>
                            </div>
                        }

                        <div class="col-lg-12 mt-2">
                            <a href="@WhatsAppService.GetSettlementOrderUrl(order)"
                               target="_blank"
                               class="btn btn-outline-success d-flex align-items-center justify-content-center gap-2 w-100 py-2 shadow-sm border-2">
                                <i class="bx bxl-whatsapp fs-24"></i>
                                <span class="fw-bold">ანგარიშსწორება WhatsApp-ით</span>
                            </a>
                        </div>

                        <div class="d-grid mt-2">
                            <button @onclick="GoHome" class="btn btn-primary py-2-5 rounded-3 fw-bold fs-14 shadow-sm">
                                <iconify-icon icon="solar:home-2-linear" class="me-1 align-middle"></iconify-icon>
                                მთავარი გვერდი
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-32 { font-size: 32px; }
    .fs-20 { font-size: 20px; }
    .fs-14 { font-size: 14px; }
    .fs-12 { font-size: 12px; }
    .fs-13 { font-size: 13px; }
    .fs-11 { font-size: 11px; }
    .fw-black { font-weight: 900; }
    .py-2-5 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
    .bg-light-subtle { background-color: var(--bs-tertiary-bg) !important; }
    .bg-primary-subtle { background-color: rgba(13, 110, 253, 0.08) !important; }
    .border-dashed { border-top: 1px dashed var(--bs-border-color) !important; height: 1px; width: 100%; }
    .animated-pop-in { animation: popIn 0.3s ease-out; }

    @@keyframes popIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .points-toast { background-color: rgba(255, 193, 7, 0.1) !important; }
    .pickup-info-card { border-left-color: #0d6efd !important; }
</style>

@code {
    [Parameter] public string OrderNumber { get; set; }
    private Order? order;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            order = await OrderService.GetOrderByIdAsync(OrderNumber);
            if (order == null) NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            NavigationManager.NavigateTo("/");
        }
    }

    private void GoHome() => NavigationManager.NavigateTo("/products");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
            StateHasChanged();
        }
    }
}