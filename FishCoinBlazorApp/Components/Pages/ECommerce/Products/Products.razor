@page "/products"
@using FishCoinBlazorApp.Services
@using FishCoinBlazorApp.Entites.Product
@using FishCoinBlazorApp.Entites.Product.Category
@inject CartService CartService
@inject ProductService ProductService
@inject ProductCategoryService ProductCategoryService
@inject SubCategoryService SubCategoryService
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime

<Topbar Title="პროდუქტები" />

<div class="row">
    <div class="col-lg-3">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-body p-2 bg-light rounded">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><i class='bx bx-search'></i></span>
                    <input type="search" class="form-control border-0 bg-transparent shadow-none"
                           placeholder="ძიება..." @oninput="OnSearchChanged">
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body border-bottom">
                <h6 class="fw-bold mb-3 text-uppercase fs-12" style="letter-spacing: 1px;">კატეგორია</h6>
                <div class="d-flex flex-column gap-2">
                    @if (subCategories == null)
                    {
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    }
                    else
                    {
                        @foreach (var sub in subCategories)
                        {
                            <div class="form-check custom-checkbox">
                                <input type="checkbox" class="form-check-input shadow-none cursor-pointer" id="sub-@sub.Id"
                                       checked="@selectedSubCategoryIds.Contains(sub.Id)"
                                       @onchange="(e) => OnSubCategorySelected(sub.Id, e.Value)">
                                <label class="form-check-label cursor-pointer fs-14 @(selectedSubCategoryIds.Contains(sub.Id) ? "fw-bold text-primary" : "")" for="sub-@sub.Id">
                                    @sub.SubCategoryName
                                </label>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card-body">
                <h6 class="fw-bold mb-3 text-uppercase fs-12" style="letter-spacing: 1px;">ტიპი</h6>
                <div class="d-flex flex-column gap-2">
                    @if (productCategories == null || !productCategories.Any())
                    {
                        <p class="text-muted fs-13 italic">აირჩიეთ ქვე-კატეგორია...</p>
                    }
                    else
                    {
                        @foreach (var pc in productCategories)
                        {
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input shadow-none cursor-pointer" id="pc-@pc.Id"
                                       checked="@selectedProductCategoryIds.Contains(pc.Id)"
                                       @onchange="(e) => OnProductCategorySelected(pc.Id, e.Value)">
                                <label class="form-check-label cursor-pointer fs-14" for="pc-@pc.Id">@pc.ProductCategoryName</label>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card-footer bg-light border-0">
                <button class="btn btn-link btn-sm text-decoration-none w-100" @onclick="ResetFilters">გასუფთავება</button>
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm">
            <div>
                <p class="mb-0 text-muted">ნაჩვენებია <span class="text-dark fw-bold">@totalCount</span> პროდუქტი</p>
            </div>
            <select class="form-select form-select-sm w-auto border-0 bg-light shadow-none cursor-pointer">
                <option>უახლესი</option>
                <option>ფასი: კლებადობით</option>
                <option>ფასი: ზრდადობით</option>
            </select>
        </div>

        @if (products == null)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (!products.Any())
        {
            <div class="text-center py-5 bg-white rounded shadow-sm">
                <i class='bx bx-package fs-1 text-muted'></i>
                <p class="mt-2 text-muted">პროდუქტები ვერ მოიძებნა</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in products)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="card h-100 shadow-sm border-0 product-card rounded-4 overflow-hidden">
                            <div class="position-relative">
                                <a href="/product-details/@item.Id">
                                    <img src="@item.ImageUrl" class="card-img-top object-fit-cover" style="height: 200px;">
                                </a>
                                @if (item.DiscountPrecentage > 0)
                                {
                                    <span class="badge bg-danger position-absolute top-0 start-0 m-3 shadow-sm">-@item.DiscountPrecentage%</span>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <span class="fs-11 text-primary fw-bold text-uppercase mb-1">@item.ProductCategory?.ProductCategoryName</span>
                                <a href="/product-details/@item.Id" class="text-dark fw-bold fs-14 text-decoration-none mb-3 text-truncate-2">@item.Name</a>

                                <div class="mt-auto">
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <h5 class="text-dark fw-bolder mb-0">@(item.DiscountPrecentage > 0 ? item.DiscountPrice : item.Price) ₾</h5>
                                        @if (item.DiscountPrecentage > 0)
                                        {
                                            <span class="text-muted text-decoration-line-through fs-12">@item.Price ₾</span>
                                        }
                                    </div>
                                    <button class="btn btn-primary w-100 rounded-3 py-2 d-flex align-items-center justify-content-center gap-2 shadow-sm"
                                            disabled="@(item.StockQuantity < 1)"
                                            @onclick="() => HandleAddToCart(item)">
                                        <i class='bx bx-cart-add fs-18'></i>
                                        <span class="fw-bold fs-13">@(item.StockQuantity > 0 ? "დამატება" : "ამოიწურა")</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (TotalPages > 1)
            {
                <nav class="mt-5">
                    <ul class="pagination justify-content-center gap-2">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link border-0 rounded-3 shadow-none bg-light text-dark" @onclick="() => LoadPage(currentPage - 1)">წინა</button>
                        </li>
                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var p = i;
                            <li class="page-item @(p == currentPage ? "active" : "")">
                                <button class="page-link border-0 rounded-3 shadow-none @(p == currentPage ? "bg-primary text-white" : "bg-light text-dark")" @onclick="() => LoadPage(p)">@p</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                            <button class="page-link border-0 rounded-3 shadow-none bg-light text-dark" @onclick="() => LoadPage(currentPage + 1)">შემდეგი</button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@if (showToast)
{
    <div class="position-fixed bottom-0 end-0 p-4" style="z-index: 1060">
        <div class="toast show text-white bg-dark border-0 shadow-lg rounded-4 animate__animated animate__fadeInUp">
            <div class="d-flex p-3 align-items-center">
                <i class='bx bxs-check-circle text-success fs-4 me-2'></i>
                <div class="fw-bold">კალათაში დაემატა!</div>
                <button type="button" class="btn-close btn-close-white ms-auto shadow-none" @onclick="() => showToast = false"></button>
            </div>
        </div>
    </div>
}

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .fs-11 {
        font-size: 11px;
    }

    .fs-12 {
        font-size: 12px;
    }

    .fs-14 {
        font-size: 14px;
    }

    .product-card {
        transition: transform 0.2s;
    }

        .product-card:hover {
            transform: translateY(-5px);
        }
</style>

@code {
    private List<Product>? products;
    private List<SubCategory>? subCategories; // სპინინგი, კარპი...
    private List<ProductCategory>? productCategories; // ჯოხები, კოჭები...

    private List<int?> selectedSubCategoryIds = new();
    private List<int?> selectedProductCategoryIds = new();

    private string searchTerm = "";
    private int totalCount;
    private int pageSize = 9;
    private int currentPage = 1;
    private bool showToast = false;

    [Parameter]
    [SupplyParameterFromQuery]
    public int? categoryId { get; set; } // ძირითადი კატეგორია URL-იდან

    protected override async Task OnParametersSetAsync()
    {
        // როცა URL იცვლება (მაგ: სათევზაოდან გადადის სანადიროზე)
        selectedSubCategoryIds.Clear();
        selectedProductCategoryIds.Clear();
        productCategories = new();

        // მოგვაქვს მხოლოდ იმ Sub-ების სია, რომლებიც ამ CategoryId-ს ეკუთვნის
        var allSub = await SubCategoryService.GetAllSubCategoriesAsync();
        if (categoryId.HasValue)
            subCategories = allSub.Where(s => s.CategoryId == categoryId.Value).ToList();
        else
            subCategories = allSub;

        await LoadPage(1);
    }

    private async Task OnSubCategorySelected(int subId, object? isChecked)
    {
        if ((bool)(isChecked ?? false))
            selectedSubCategoryIds.Add(subId);
        else
            selectedSubCategoryIds.Remove(subId);

        // როცა SubCategory იცვლება, თავიდან მოგვაქვს ProductCategory-ები (ჯოხები, კოჭები)
        productCategories = new();
        foreach (var subIdItem in selectedSubCategoryIds)
        {
            var pCats = await ProductCategoryService.GetAllProductCategoriesAsync(subIdItem);
            productCategories.AddRange(pCats);
        }

        // ვასუფთავებთ არჩეულ პროდუქტის კატეგორიებს, თუ ისინი აღარ არიან სიაში
        selectedProductCategoryIds = selectedProductCategoryIds
            .Where(id => productCategories.Any(pc => pc.Id == id)).ToList();

        await LoadPage(1);
    }

    private async Task OnProductCategorySelected(int pcId, object? isChecked)
    {
        if ((bool)(isChecked ?? false))
            selectedProductCategoryIds.Add(pcId);
        else
            selectedProductCategoryIds.Remove(pcId);

        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        currentPage = page;

        // ProductService-ს ვუგზავნით ProductCategory-ების ლისტს ფილტრაციისთვის.
        // თუ არჩეულია ProductCategory, ფილტრავს იმით.
        // თუ მხოლოდ SubCategory-ა მონიშნული, ფილტრავს იმით.
        // თუ არაფერია, ფილტრავს CategoryId-ით.

        var result = await ProductService.GetPagedProductsAsync(
            currentPage,
            pageSize,
            selectedProductCategoryIds.Any() ? selectedProductCategoryIds : selectedSubCategoryIds,
            searchTerm,
            categoryId);

        products = result.Products;
        totalCount = result.TotalCount;
        StateHasChanged();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        await LoadPage(1);
    }

    private async Task ResetFilters()
    {
        selectedSubCategoryIds.Clear();
        selectedProductCategoryIds.Clear();
        productCategories = new();
        searchTerm = "";
        await LoadPage(1);
    }

    private async Task HandleAddToCart(Product item)
    {
        await CartService.AddToCart(new Services.Models.ProductDetailModel
        {
            Id = item.Id,
            Name = item.Name,
            Price = item.Price,
            ImageUrl = item.ImageUrl
        }, 1);
        showToast = true;
        StateHasChanged();
        await Task.Delay(2500);
        showToast = false;
        StateHasChanged();
    }

    private int TotalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
    }
}