@page "/products"
@using FishCoinBlazorApp.Services
@using FishCoinBlazorApp.Services.RouteServices
@using FishCoinBlazorApp.Entites.Product
@using FishCoinBlazorApp.Entites.Product.Category
@using FishCoinBlazorApp.Helpers
@inject CartService CartService
@inject ProductService ProductService
@inject ProductCategoryService ProductCategoryService
@inject SubCategoryService SubCategoryService
@inject UserService UserService
@inject RedeemStateService RedeemStateService
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager

<Topbar Title="პროდუქტები" />

<div class="row mx-0 g-3 mt-2">
    <div class="col-lg-3 px-2">
        @* ძებნის ბლოკი *@
        <div class="card mb-3 shadow-sm border-0 bg-transparent">
            <div class="card-body p-2 custom-bg-alt rounded shadow-none border">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><i class='bx bx-search opacity-75'></i></span>
                    <input type="search" class="form-control border-0 bg-transparent shadow-none"
                           placeholder="ძიება..." @oninput="OnSearchChanged">
                    </div>
                </div>
            </div>

            @* ფილტრების ბლოკი *@
            <div class="card shadow-sm border custom-bg rounded-4 overflow-hidden">
                <div class="card-body border-bottom">
                    <h6 class="fw-bold mb-3 text-uppercase fs-12" style="letter-spacing: 1px;">კატეგორია</h6>
                    <div class="d-flex flex-column gap-2">
                        @if (subCategories == null)
                        {
                            <div class="spinner-border spinner-border-sm text-primary"></div>
                        }
                        else
                        {
                            @foreach (var sub in subCategories)
                            {
                                <div class="form-check custom-checkbox">
                                    <input type="checkbox" class="form-check-input shadow-none cursor-pointer" id="sub-@sub.Id"
                                           checked="@selectedSubCategoryIds.Contains(sub.Id)"
                                           @onchange="(e) => OnSubCategorySelected(sub.Id, e.Value)">

                                        <label class="form-check-label cursor-pointer fs-14 @(selectedSubCategoryIds.Contains(sub.Id) ? "fw-bold text-primary" : "")"
                                               for="sub-@sub.Id">
                                            @sub.SubCategoryName
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="card-body">
                        <h6 class="fw-bold mb-3 text-uppercase fs-12" style="letter-spacing: 1px;">ტიპი</h6>
                        <div class="d-flex flex-column gap-2">
                            @if (productCategories == null || !productCategories.Any())
                            {
                                <p class="opacity-50 fs-13 italic">აირჩიეთ ქვე-კატეგორია...</p>
                            }
                            else
                            {
                                @foreach (var pc in productCategories)
                                {
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input shadow-none cursor-pointer" id="pc-@pc.Id"
                                               checked="@selectedProductCategoryIds.Contains(pc.Id)"
                                               @onchange="(e) => OnProductCategorySelected(pc.Id, e.Value)">
                                            <label class="form-check-label cursor-pointer fs-14" for="pc-@pc.Id">@pc.ProductCategoryName</label>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <div class="card-footer border-top-0 bg-transparent pb-3">
                            @* გასუფთავება - ლურჯი ბექგრაუნდით *@
                            <button class="btn btn-primary btn-sm w-100 rounded-3 shadow-sm fw-bold d-flex align-items-center justify-content-center gap-2 py-2" @onclick="ResetFilters">
                                <i class='bx bx-refresh fs-18'></i> გასუფთავება
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-9 px-2">
                    @* პროდუქტების სტატისტიკა და გამოკვეთილი Dropdown *@
                    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded-4 shadow-sm custom-bg border">
                        <div>
                            <p class="mb-0 opacity-75 fs-14">ნაჩვენებია <span class="fw-bold text-reset">@totalCount</span> პროდუქტი</p>
                        </div>
                        <select class="form-select form-select-sm w-auto border-0 custom-bg-alt shadow-sm cursor-pointer fw-bold rounded-3 px-3 py-2"
                                style="min-width: 160px;"
                                @onchange="OnSortChanged">
                            <option value="price_asc">ზრდადობით</option>
                            <option value="price_desc">კლებადობით</option>
                            <option value="newest">უახლესი</option>
                            <option value="discount">ფასდაკლებული</option>
                        </select>
                    </div>

                    @if (products == null)
                    {
                        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
                    }
                    else if (!products.Any())
                    {
                        <div class="text-center py-5 rounded-4 shadow-sm custom-bg border">
                            <i class='bx bx-package fs-1 opacity-50'></i>
                            <p class="mt-2 opacity-75">პროდუქტები ვერ მოიძებნა</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-4">
                            @foreach (var item in products)
                            {
                                if ((selectedSubCategoryIds != null && selectedSubCategoryIds.Count > 0 && selectedSubCategoryIds.Contains(6))
                                || categoryId == 3)
                                {
                                    <div class="col-md-6 col-xl-4">
                                        <div class="card h-100 shadow-sm border-0 product-card rounded-4 overflow-hidden custom-bg border">
                                            <div class="position-relative">
                                                <a href="/redeem-product-details/@item.Id/@item.Name.ToUrlSlug()">
                                                    <img src="@item.ImageUrl" class="card-img-top object-fit-cover rounded-4" style="height: 200px;">
                                                </a>
                                            </div>
                                            <div class="card-body d-flex flex-column p-3">
                                                <span class="fs-11 text-primary fw-bold text-uppercase mb-1">@item.ProductCategory?.ProductCategoryName</span>
                                                <a href="/redeem-product-details/@item.Id/@item.Name.ToUrlSlug()" class="text-reset fw-bold fs-14 text-decoration-none mb-3 text-truncate-2">@item.Name</a>
                                                <div class="text-muted fs-12 mb-3 text-truncate" title="@item.Description">
                                                    @item.Description
                                                </div>
                                                <div class="mt-auto">
                                                    <div class="d-flex align-items-center gap-2 mb-3">
                                                        <h5 class="fw-bolder mb-0">@(item.PointsPrice) ქულა</h5>
                                                    </div>
                                                    <button class="btn btn-primary w-100 rounded-3 py-2 d-flex align-items-center justify-content-center gap-2 shadow-sm"
                                                            disabled="@(item.StockQuantity < 1)"
                                                            @onclick="() => OrderRedeemProduct(item.Id, item.Name)">
                                                        <i class='bx bx-cart-add fs-18'></i>
                                                        <span class="fw-bold fs-13">@(item.StockQuantity > 0 ? "საჩუქრის მიღება" : "ამოიწურა")</span>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="col-md-6 col-xl-4">
                                        <div class="card h-100 shadow-sm border-0 product-card rounded-4 overflow-hidden custom-bg border">
                                            <div class="position-relative">
                                                <a href="/product-details/@item.Id/@item.Name.ToUrlSlug()">
                                                    <img src="@item.ImageUrl" class="card-img-top object-fit-cover rounded-4" style="height: 200px;">
                                                </a>
                                                @if (item.DiscountPrecentage > 0)
                                                {
                                                    <span class="badge bg-danger position-absolute top-0 start-0 m-3 shadow-sm">-@item.DiscountPrecentage%</span>
                                                }
                                            </div>
                                            <div class="card-body d-flex flex-column p-3">
                                                <span class="fs-11 text-primary fw-bold text-uppercase mb-1">@item.ProductCategory?.ProductCategoryName</span>
                                                <a href="/product-details/@item.Id/@item.Name.ToUrlSlug()" class="text-reset fw-bold fs-14 text-decoration-none mb-3 text-truncate-2">@item.Name</a>
                                                <div class="text-muted fs-12 mb-3 text-truncate" title="@item.Description">
                                                    @item.Description
                                                </div>
                                                <div class="mt-auto">
                                                    <div class="d-flex align-items-center gap-2 mb-3">
                                                        <h5 class="fw-bolder mb-0">@(item.DiscountPrecentage > 0 ? item.DiscountPrice : item.Price) ₾</h5>
                                                        @if (item.DiscountPrecentage > 0)
                                                        {
                                                            <span class="opacity-50 text-decoration-line-through fs-12">@item.Price ₾</span>
                                                        }
                                                    </div>
                                                    <button class="btn btn-primary w-100 rounded-3 py-2 d-flex align-items-center justify-content-center gap-2 shadow-sm"
                                                            disabled="@(item.StockQuantity < 1)"
                                                            @onclick="() => HandleAddToCart(item)">
                                                        <i class='bx bx-cart-add fs-18'></i>
                                                        <span class="fw-bold fs-13">@(item.StockQuantity > 0 ? "დამატება" : "ამოიწურა")</span>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        @if (TotalPages > 1)
                        {
                            <nav class="mt-5">
                                <ul class="pagination justify-content-center gap-2">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link border-0 rounded-3 shadow-none opacity-75 custom-bg-alt text-reset" @onclick="() => LoadPage(currentPage - 1)">წინა</button>
                                    </li>
                                    @for (int i = 1; i <= TotalPages; i++)
                                    {
                                        var p = i;
                                        <li class="page-item @(p == currentPage ? "active" : "")">
                                            <button class="page-link border-0 rounded-3 shadow-none @(p == currentPage ? "bg-primary text-white" : "custom-bg-alt text-reset")" @onclick="() => LoadPage(p)">@p</button>
                                        </li>
                                    }
                                    <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                                        <button class="page-link border-0 rounded-3 shadow-none opacity-75 custom-bg-alt text-reset" @onclick="() => LoadPage(currentPage + 1)">შემდეგი</button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    }
                </div>
            </div>

            @if (showToast)
            {
                <div class="position-fixed bottom-0 end-0 p-4" style="z-index: 1060">
                    <div class="toast show text-white bg-dark border-0 shadow-lg rounded-4 animate__animated animate__fadeInUp">
                        <div class="d-flex p-3 align-items-center">
                            <i class='bx bxs-check-circle text-success fs-4 me-2'></i>
                            <div class="fw-bold">კალათაში დაემატა!</div>
                            <button type="button" class="btn-close btn-close-white ms-auto shadow-none" @onclick="() => showToast = false"></button>
                        </div>
                    </div>
                </div>
            }

            <style>
                .custom-bg {
                    background-color: var(--bs-body-bg) !important;
                }

                .cursor-pointer {
                    cursor: pointer;
                }

                .fs-11 {
                    font-size: 11px;
                }

                .fs-12 {
                    font-size: 12px;
                }

                .fs-13 {
                    font-size: 13px;
                }

                .fs-14 {
                    font-size: 14px;
                }

                .product-card {
                    transition: transform 0.2s;
                    background-color: var(--bs-body-bg) !important;
                }

                    .product-card:hover {
                        transform: translateY(-5px);
                    }

                .text-truncate-2 {
                    display: -webkit-box;
                    -webkit-line-clamp: 2;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                }

                .page-link {
                    color: inherit;
                }
            </style>

@code {
    private List<Product>? products;
    private List<SubCategory>? subCategories;
    private List<ProductCategory>? productCategories;
    private List<int?> selectedSubCategoryIds = new();
    private List<int?> selectedProductCategoryIds = new();
    private string sortBy = "price_asc";
    private string searchTerm = "";
    private int totalCount;
    private int pageSize = 9;
    private int currentPage = 1;
    private bool showToast = false;

    [Parameter]
    [SupplyParameterFromQuery]
    public int? categoryId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        selectedSubCategoryIds.Clear();
        selectedProductCategoryIds.Clear();
        productCategories = new();
        var allSub = await SubCategoryService.GetAllSubCategoriesAsync();
        if (categoryId.HasValue)
            subCategories = allSub.Where(s => s.CategoryId == categoryId.Value).ToList();
        else
            subCategories = allSub;
        await LoadPage(1);
    }

    private async Task OnSubCategorySelected(int subId, object? isChecked)
    {
        bool isSelected = (bool)(isChecked ?? false);

        selectedSubCategoryIds.Clear();

        if (isSelected)
        {
            selectedSubCategoryIds.Add(subId);
        }

        productCategories = new();

        if (selectedSubCategoryIds.Any())
        {
            var currentSubId = selectedSubCategoryIds.First();
            var pCats = await ProductCategoryService.GetAllProductCategoriesAsync(currentSubId);
            productCategories.AddRange(pCats);
        }

        selectedProductCategoryIds = selectedProductCategoryIds
            .Where(id => productCategories.Any(pc => pc.Id == id)).ToList();

        await LoadPage(1);
    }

    private async Task OnProductCategorySelected(int pcId, object? isChecked)
    {
        if ((bool)(isChecked ?? false)) selectedProductCategoryIds.Add(pcId);
        else selectedProductCategoryIds.Remove(pcId);
        await LoadPage(1);
    }

    // Paging-ის მთავარი მეთოდი
    private async Task LoadPage(int page)
    {
        currentPage = page;
        var result = await ProductService.GetPagedProductsAsync(
            currentPage, pageSize,
            selectedProductCategoryIds,
            selectedSubCategoryIds,
            searchTerm, categoryId, sortBy);

        products = result.Products;
        totalCount = result.TotalCount;
        StateHasChanged();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        await LoadPage(1);
    }

    private async Task ResetFilters()
    {
        selectedSubCategoryIds.Clear();
        selectedProductCategoryIds.Clear();
        productCategories = new();
        searchTerm = "";
        await LoadPage(1);
    }

    private async Task HandleAddToCart(Product item)
    {
        await CartService.AddToCart(new Services.Models.ProductDetailModel
        {
            Id = item.Id,
            Name = item.Name,
            Price = item.Price,
            ImageUrl = item.ImageUrl,
            StockQuantity = item.StockQuantity,
            PointsReward = item.PointsReward
        }, 1);
        showToast = true;
        StateHasChanged();
        await Task.Delay(2500);
        showToast = false;
        StateHasChanged();
    }

    private async Task OrderRedeemProduct(int productId, string name)
    {
        var user = await UserService.GetCurrentUserAsync();
        if (user == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        NavigationManager.NavigateTo($"/RedeemCheckout/{name.ToUrlSlug()}?rid={productId}");
    }

    private async Task<bool> CheckUserIsAuthorized()
    {
        var user = await UserService.GetCurrentUserAsync();
        if (user == null)
        {
            // ამოვიღეთ forceLoad: true
            NavigationManager.NavigateTo("/login");
            return false;
        }
        return true;
    }

    private async Task OnSortChanged(ChangeEventArgs e)
    {
        sortBy = e.Value?.ToString() ?? "newest";
        await LoadPage(1);
    }

    private int TotalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
    }
}