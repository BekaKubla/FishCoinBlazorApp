@page "/products"
@using FishCoinBlazorApp.Services
@using FishCoinBlazorApp.Entites.Product
@using FishCoinBlazorApp.Entites.Product.Category
@inject FishCoinBlazorApp.Services.CartService CartService
@inject ProductService ProductService
@inject ProductCategoryService ProductCategoryService
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime;


<Topbar Title="პროდუქტები" />

<div class="row">
    <div class="col-lg-3">
        <div class="card">
            <div class="card-header border-0">
                <div class="search-bar me-3 mb-1">
                    <span><i class="bx bx-search-alt"></i></span>
                    <input type="search" class="form-control" id="search" placeholder="ძიება ..."
                           @oninput="OnSearchChanged">
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body border-light">
                <a href="#" class="btn-link d-flex align-items-center text-dark p-2 rounded fw-medium fs-16 mb-0" data-bs-toggle="collapse" data-bs-target="#categories" aria-expanded="false" aria-controls="other">
                    კატეგორიები
                    <i class='bx bx-chevron-down ms-auto fs-20'></i>
                </a>
                <div id="categories" class="collapse show">
                    <div class="categories-list d-flex flex-column gap-2 mt-2">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="all-categories" checked>
                            <label class="form-check-label" for="all-categories">ყველა</label>
                        </div>
                        @if (productCategories == null)
                        {
                            <p>კატეგორიები იტვირთება...</p>
                        }
                        else
                        {
                            @foreach (var item in productCategories)
                            {
                                <div class="form-check">
                                    @* id-ს ვამატებთ item.Id-ს რომ უნიკალური იყოს *@
                                    <input type="checkbox" class="form-check-input" id="cat-@item.Id"
                                           @onchange="(e) => OnCategorySelected(item.Id, e.Value)">
                                    <label class="form-check-label" for="cat-@item.Id">@item.ProductCategoryName</label>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <a href="#!" class="btn btn-primary w-100">ძიება</a>
            </div>
        </div>
    </div>
    <div class="col-lg-9">
        <div class="card">
            <div class="card-header border-0">
                <div class="row justify-content-between align-items-center">
                    <div class="col-lg-6">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item fw-medium"><a href="javascript: void(0);" class="text-dark">კატეგორია</a></li>
                            <li class="breadcrumb-item active">ყველა</li>
                        </ol>
                        <p class="mb-0 text-muted">ნაჩვენებია <span class="text-dark fw-semibold">@totalCount</span> პროდუქტი</p>
                    </div>
                </div>
            </div>
        </div>
        @if (products == null)
        {
            <p><em>იტვირთება...</em></p>
        }
        else
        {
            @* დავამატეთ g-4 დაშორებებისთვის *@
            <div class="row g-4">
                @foreach (var item in products)
                {
                    <div class="col-md-6 col-xl-3">
                        @* card-იდან mb-4 შეგიძლია მოაშორო, რადგან g-4 მიხედავს ყველაფერს *@
                        <div class="card h-100 shadow-sm border-0 translate-y-hover transition-all">
                            <div class="position-relative overflow-hidden rounded-top">
                                @* პროდუქტის სურათი *@
                                <a href="@($"/product-details/{item.Id}")">
                                    <img src="@item.ImageUrl" alt="" class="img-fluid w-100 object-fit-cover" style="height: 220px;">
                                </a>

                                @if (item.DiscountPrecentage.HasValue && item.DiscountPrecentage > 0)
                                {
                                    <span class="position-absolute top-0 start-0 m-2 badge bg-danger rounded-pill">
                                        -@item.DiscountPrecentage%
                                    </span>
                                }
                            </div>

                            <div class="card-body p-3 d-flex flex-column">
                                <p class="text-muted fs-12 mb-1 uppercase">@item.ProductCategory.ProductCategoryName</p>

                                <a href="@($"/product-details/{item.Id}")" class="text-dark fw-bold fs-15 mb-2 d-block text-truncate">
                                    @item.Name
                                </a>

                                <div class="mt-auto">
                                    @if (item.DiscountPrecentage.HasValue && item.DiscountPrecentage > 0)
                                    {
                                        <div class="d-flex align-items-center gap-2 mb-3">
                                            <h5 class="text-primary fw-bold mb-0">@item.DiscountPrice ₾</h5>
                                            <span class="text-muted text-decoration-line-through fs-13">@item.Price ₾</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <h5 class="text-dark fw-bold mb-3">@item.Price ₾</h5>
                                    }

                                    @* პროდუქტების ლისტში არსებული ღილაკი *@
                                    <button class="btn btn-soft-primary w-100 d-flex align-items-center justify-content-center gap-2"
                                            disabled="@(item.StockQuantity < 1)"
                                            @onclick="() => HandleAddToCart(item)">
                                        <iconify-icon icon="solar:cart-large-2-bold" class="fs-18"></iconify-icon>
                                        <span>@(item.StockQuantity >= 1 ? "დამატება" : "ამოიწურა")</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="py-3 border-top">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-end mb-0">
                    @* Previous ღილაკი *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" @onclick="() => LoadPage(currentPage - 1)" href="javascript:void(0);">წინა</a>
                    </li>

                    @* გვერდების ნომრები *@
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNumber = i;
                        <li class="page-item @(pageNumber == currentPage ? "active" : "")">
                            <a class="page-link" @onclick="() => LoadPage(pageNumber)" href="javascript:void(0);">@pageNumber</a>
                        </li>
                    }

                    @* Next ღილაკი *@
                    <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                        <a class="page-link" @onclick="() => LoadPage(currentPage + 1)" href="javascript:void(0);">შემდეგი</a>
                    </li>
                </ul>
            </nav>
        </div>

    </div>

    @if (showToast)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
            <div class="toast show align-items-center text-white bg-primary border-0 shadow-lg ripple-animation" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bx bx-check-circle fs-20"></i>
                        <div>
                            <strong>დაემატა!</strong><br />
                            პროდუქტი დაემატა კალათაში.
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => showToast = false"></button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private IJSObjectReference? _module;

    // მონაცემების ცვლადები
    private List<Product>? products;
    private List<ProductCategory>? productCategories;
    private List<int?> selectedProductIds = new();
    private string searchTerm = "";
    private int totalCount;
    private int pageSize = 8;
    private int currentPage = 1;

    [Parameter]
    [SupplyParameterFromQuery]
    public int? categoryId { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // ეს ხაზი აიტანს სქროლს ზემოთ მხოლოდ ამ გვერდზე შემოსვლისას
                await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
                _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/pages/ecommerce-product.js");
                await JsRuntime.InvokeVoidAsync("loadProduct");
                await JsRuntime.InvokeVoidAsync("loadThemeConfig");
                await JsRuntime.InvokeVoidAsync("loadApps");
            }
            catch (Exception ex)
            {
                Console.WriteLine("JS Error: " + ex.Message);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        productCategories = await ProductCategoryService.GetAllProductCategoriesAsync(categoryId);
        await LoadPage(1);
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";

        await LoadPage(1);
    }

    protected override async Task OnParametersSetAsync()
    {
        selectedProductIds.Clear();

        productCategories = await ProductCategoryService.GetAllProductCategoriesAsync(categoryId);

        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        currentPage = page;
        var result = await ProductService.GetPagedProductsAsync(currentPage, pageSize, selectedProductIds, searchTerm, categoryId);

        products = result.Products;
        totalCount = result.TotalCount;

        StateHasChanged();
    }

    private async Task OnCategorySelected(int categoryId, object? isChecked)
    {
        bool checkedValue = (bool)(isChecked ?? false);

        if (checkedValue)
            selectedProductIds.Add(categoryId);
        else
            selectedProductIds.Remove(categoryId);

        await LoadPage(1);
    }

    private bool showToast = false;

    private async Task HandleAddToCart(Product item)
    {
        if (item.StockQuantity >= 1)
        {
            await CartService.AddToCart(new Services.Models.ProductDetailModel
                {
                    Id = item.Id,
                    StockQuantity = item.StockQuantity,
                    Description = item.Description,
                    DiscountPrecentage = item.DiscountPrecentage,
                    DiscountPrice = item.DiscountPrice,
                    ImageUrl = item.ImageUrl,
                    Name = item.Name,
                    PointsReward = item.PointsReward,
                    Price = item.Price,
                    TagNumber = item.TagNumber,
                }, 1);

            showToast = true;
            StateHasChanged();

            await Task.Delay(3000);
            showToast = false;
            StateHasChanged();
        }
    }

    private int TotalPages => totalCount == 0 ? 1 : (int)Math.Ceiling((double)totalCount / pageSize);
}