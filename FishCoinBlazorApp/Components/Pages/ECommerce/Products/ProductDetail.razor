@page "/product-details/{Id:int}/{Slug}"
@rendermode InteractiveServer
@using FishCoinBlazorApp.Services
@using FishCoinBlazorApp.Services.Models
@using FishCoinBlazorApp.Helpers
@inject ProductService ProductService
@inject CartService CartService
@inject WhatsAppService WhatsAppService
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime;

@* სტილი სწორი დაშორებებისთვის *@
<style>
    .main-wrapper {
        min-height: 100vh;
        background-color: var(--bs-body-bg);
    }
</style>

<div class="main-wrapper bg-body">
    <Topbar Title="პროდუქტი დეტალურად" />

    @* კონტეინერი სწორი padding-ით, რომ Topbar-მა არ გადაფაროს *@
    <div class="container-fluid px-3 px-md-4 pt-3 pb-5">

        @if (productDetail == null && !isNotFound)
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">იტვირთება...</span>
                </div>
            </div>
        }
        else if (isNotFound)
        {
            <div class="text-center p-5">
                <iconify-icon icon="solar:danger-bold-duotone" class="text-danger fs-64"></iconify-icon>
                <h3 class="mt-3">პროდუქტი ვერ მოიძებნა</h3>
                <p class="text-muted">სამწუხაროდ, მითითებული პროდუქტი არ არსებობს.</p>
                <a href="/products" class="btn btn-primary mt-2">დაბრუნება ჩამონათვალში</a>
            </div>
        }
        else
        {
            @* --- SEO & Metadata Section --- *@
            <HeadContent>
                <meta name="description" content="@(productDetail?.Description?.Length > 160 ? productDetail.Description.Substring(0, 157) + "..." : productDetail?.Description)" />
                <meta property="og:title" content="@productDetail?.Name" />
                <meta property="og:description" content="@productDetail?.Description" />
                <meta property="og:image" content="@($"{NavigationManager.BaseUri}{productDetail?.ImageUrl?.TrimStart('/')}")" />
                <meta property="og:type" content="product" />
                <meta property="og:url" content="@NavigationManager.Uri" />
                <meta property="product:price:amount" content="@productDetail?.Price" />
                <meta property="product:price:currency" content="GEL" />
                <meta property="product:availability" content="@(productDetail?.StockQuantity > 0 ? "instock" : "oos")" />

                <script type="application/ld+json">
                                {
                                  "@@context": "https://schema.org/",
                                  "@@type": "Product",
                                  "name": "@productDetail?.Name",
                                  "image": "@productDetail?.ImageUrl",
                                  "description": "@productDetail?.Description",
                                  "brand": {
                                    "@@type": "Brand",
                                    "name": "FishCoin"
                                  },
                                  "offers": {
                                    "@@type": "Offer",
                                    "url": "@NavigationManager.Uri",
                                    "priceCurrency": "GEL",
                                    "price": "@productDetail?.Price",
                                    "availability": "https://schema.org/@(productDetail?.StockQuantity > 0 ? "InStock" : "OutOfStock")",
                                    "itemCondition": "https://schema.org/NewCondition"
                                  }
                                }
                </script>
            </HeadContent>

            @* --- Breadcrumbs Section --- *@
            <div class="row mb-3">
                <div class="col-12">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/" class="text-primary text-decoration-none">მთავარი</a></li>
                            <li class="breadcrumb-item"><a href="/products" class="text-primary text-decoration-none">პროდუქტები</a></li>
                            <li class="breadcrumb-item active text-muted" aria-current="page">@productDetail?.Name</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-4">
                    @* შესწორებული ხაზი: მოვაშორე h-100 კლასი *@
                    <div class="card">
                        <div class="card-body">
                            <div id="carouselExampleFade" class="carousel slide carousel-fade" data-bs-ride="carousel">
                                <div class="carousel-inner" role="listbox">
                                    <div class="carousel-item active">
                                        <img src="@(productDetail!.ImageUrl)" alt="" class="img-fluid rounded shadow-sm">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top bg-light-subtle">
                            <div class="row g-2">
                                <div class="col-lg-6">
                                    <button class="btn btn-primary d-flex align-items-center justify-content-center gap-2 w-100 py-2"
                                            disabled="@(productDetail.StockQuantity < 1)"
                                            @onclick="AddToCart">
                                        <i class="bx bx-cart fs-20"></i>
                                        @(productDetail.StockQuantity >= 1 ? "დამატება" : "ამოიწურა")
                                    </button>
                                </div>
                                <div class="col-lg-6">
                                    <button class="btn @(productDetail.StockQuantity >= 1 ? "btn-dark" : "btn-secondary") d-flex align-items-center justify-content-center gap-2 w-100 py-2"
                                            disabled="@(productDetail.StockQuantity < 1)"
                                            @onclick="BuyNow">
                                        <i class="bx bx-shopping-bag fs-20"></i>
                                        @(productDetail.StockQuantity >= 1 ? "ყიდვა" : "მიუწვდომელია")
                                    </button>
                                </div>
                                <div class="col-lg-12 mt-2">
                                    <a href="@WhatsAppService.GetProductOrderUrl(productDetail.Name, (productDetail.DiscountPrecentage.HasValue ? productDetail.DiscountPrice!.Value : productDetail.Price), productDetail.TagNumber, selectedQuantity)"
                                           target="_blank"
                                           class="btn btn-outline-success d-flex align-items-center justify-content-center gap-2 w-100 py-2 shadow-sm">
                                        <i class="bx bxl-whatsapp fs-24"></i>
                                        <span class="fw-bold">შეუკვეთე WhatsApp-ით</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="card h-100">
                        <div class="card-body">
                            @* შესწორებული სექცია: ბონუსის ქარდი მობილურზე სრულ სიგრძეზე *@
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                                <div class="w-100 w-sm-auto mb-2 mb-sm-0">
                                    <span class="badge bg-success-subtle text-success border border-success-subtle fs-12 px-2 py-1 uppercase">
                                        @(productDetail.IsNew ? "ახალი მიღებული" : "")
                                    </span>
                                    <h3 class="mt-2 text-dark fw-semibold lh-sm">@productDetail.Name</h3>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap align-items-baseline gap-2 my-3">
                                @if (productDetail.DiscountPrecentage.HasValue)
                                {
                                    <h2 class="fw-bold text-primary mb-0">@productDetail.DiscountPrice ₾</h2>
                                    <h4 class="text-muted text-decoration-line-through mb-0 fs-16">@productDetail.Price ₾</h4>
                                    <span class="badge bg-danger-subtle text-danger rounded-pill fs-12 py-1 px-2">
                                        -@productDetail.DiscountPrecentage% ფასდაკლება
                                    </span>
                                }
                                else
                                {
                                    <h2 class="fw-bold text-primary mb-0">@productDetail.Price ₾</h2>
                                }
                            </div>

                            <div class="alert alert-info border-0 bg-info-subtle d-flex align-items-center gap-2 mt-4" role="alert">
                                <i class='bx bx-info-circle fs-20'></i>
                                <span class="fs-14">ამ პროდუქტის შეძენით თქვენს ბალანსზე დაგერიცხებათ <strong>@productDetail.PointsReward ქულა</strong>, რომელიც დაგეხმარებათ საჩუქრის მიღებაში.</span>
                            </div>

                            <div class="quantity mt-4">
                                <h5 class="text-dark fw-medium">რაოდენობა :</h5>
                                <div class="input-step border p-1 mt-2 rounded d-inline-flex">
                                    <button type="button" class="minus btn btn-sm btn-light border-0" @onclick="DecreaseQuantity">-</button>
                                    <input type="number" class="text-center border-0 bg-transparent" @bind="selectedQuantity" readonly style="width: 50px;" />
                                    <button type="button" class="plus btn btn-sm btn-light border-0" @onclick="IncreaseQuantity">+</button>
                                </div>
                            </div>

                            <hr class="my-4">

                            <h5 class="text-dark fw-semibold">აღწერა :</h5>
                            <p class="text-muted lh-lg">@productDetail.Description</p>

                            <div class="row mt-3">
                                <div class="col-md-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="@(productDetail.StockQuantity >= 1 ? "bg-success-subtle" : "bg-danger-subtle") rounded-circle p-1 d-flex align-items-center justify-content-center">
                                            <i class='bx @(productDetail.StockQuantity >= 1 ? "bx-check text-success" : "bx-x text-danger") fs-18'></i>
                                        </div>
                                        <span class="@(productDetail.StockQuantity >= 1 ? "text-success" : "text-danger") fw-medium fs-14">
                                            @(productDetail.StockQuantity >= 1 ? "მარაგშია" : "არ არის მარაგში")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-12">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h4 class="card-title mb-0">მსგავსი პროდუქტები</h4>
                        <a href="/products" class="btn btn-sm btn-outline-primary">ყველას ნახვა</a>
                    </div>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3 mb-5">
                @if (relatedProducts != null)
                {
                    @foreach (var item in relatedProducts)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden">
                                @if (item.DiscountPrecentage.HasValue && item.DiscountPrecentage > 0)
                                {
                                    <div class="position-absolute top-0 start-0 m-2" style="z-index: 1;">
                                        <span class="badge bg-danger rounded-pill shadow-sm">-@item.DiscountPrecentage%</span>
                                    </div>
                                }
                                <div class="p-2">
                                    <a href="@($"/product-details/{item.Id}/{item.Name.ToUrlSlug()}")">
                                        <img src="@(item.ImageUrl)" class="img-fluid rounded" alt="@item.Name">
                                    </a>
                                </div>
                                <div class="card-body pt-3">
                                    <a href="@($"/product-details/{item.Id}/{item.Name.ToUrlSlug()}")" class="text-dark fw-bold fs-14 d-block text-truncate mb-2">
                                        @item.Name
                                    </a>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            @if (item.DiscountPrecentage.HasValue && item.DiscountPrecentage > 0)
                                            {
                                                <h5 class="text-primary fw-bold mb-0">@item.DiscountPrice ₾</h5>
                                                <small class="text-muted text-decoration-line-through">@item.Price ₾</small>
                                            }
                                            else
                                            {
                                                <h5 class="text-primary fw-bold mb-0">@item.Price ₾</h5>
                                            }
                                        </div>
                                        <button class="btn btn-sm btn-soft-primary p-1 lh-1" @onclick="() => HandleRelatedAddToCart(item)">
                                            <i class="bx bx-plus fs-18"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@if (showToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
        <div class="toast show align-items-center text-white bg-primary border-0 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <i class="bx bx-check-circle fs-20"></i>
                    <div><strong>დაემატა!</strong><br />პროდუქტი დაემატა კალათაში.</div>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => showToast = false"></button>
            </div>
        </div>
    </div>
}

@code {
    private IJSObjectReference? _module;
    private ProductDetailModel? productDetail;
    private bool showToast = false;
    private bool isNotFound = false;
    private List<ProductDetailModel>? relatedProducts;
    private int selectedQuantity = 1;

    [Parameter] public int Id { get; set; }
    [Parameter] public string? Slug { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
                _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/pages/ecommerce-product-details.js");
                await JsRuntime.InvokeVoidAsync("loadProductDetails");
                await JsRuntime.InvokeVoidAsync("loadThemeConfig");
                await JsRuntime.InvokeVoidAsync("loadApps");
            }
            catch { }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await OnInitializedAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        productDetail = await ProductService.GetProductById(Id);
        if (productDetail == null) { isNotFound = true; }
        else
        {
            isNotFound = false;
            relatedProducts = await ProductService.GetProductByCategory(Id);
        }
    }

    private async Task HandleRelatedAddToCart(ProductDetailModel item)
    {
        await CartService.AddToCart(item, 1);
        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }

    private async Task AddToCart()
    {
        if (productDetail != null)
        {
            await CartService.AddToCart(productDetail, selectedQuantity);
            showToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            showToast = false;
            StateHasChanged();
        }
    }

    private async Task BuyNow()
    {
        if (productDetail != null && productDetail.StockQuantity >= 1)
        {
            await CartService.ClearCart();
            await CartService.AddToCart(productDetail, selectedQuantity);
            NavigationManager.NavigateTo("/checkout");
        }
    }

    private void IncreaseQuantity()
    {
        if (productDetail != null && selectedQuantity < productDetail.StockQuantity)
            selectedQuantity++;
    }

    private void DecreaseQuantity()
    {
        if (selectedQuantity > 1)
            selectedQuantity--;
    }
}