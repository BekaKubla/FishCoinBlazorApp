@page "/about"
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime

<style>
    /* მთავარი გარემო - მოშორებულია ხისტი background-color */
    .about-main-wrapper {
        min-height: 100vh;
        margin: -20px;
        padding: 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* საკონტაქტო ბარათები - ამოღებულია background: #ffffff */
    .contact-grid-card {
        border-radius: 20px;
        padding: 30px;
        height: 100%;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        border: 1px solid rgba(226, 232, 240, 0.1); /* ნაზი ჩარჩო */
    }

        .contact-grid-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1) !important;
            border-color: #3498db !important;
        }

    .contact-icon {
        font-size: 40px;
        margin-bottom: 15px;
    }

    /* რუკის სექცია */
    .map-box {
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.2);
        height: 500px;
        margin-top: 30px;
        background: #e5e7eb;
    }

    /* რუკის ფილტრი Dark Mode-ისთვის (სურვილისამებრ) */
    [data-bs-theme='dark'] iframe {
        filter: grayscale(100%) invert(92%) contrast(83%);
    }

    iframe {
        width: 100%;
        height: 100%;
        border: none;
    }
</style>

<div class="about-main-wrapper bg-body">
    <Topbar Title="კონტაქტი" />

    <div class="container-fluid px-4">

        @* 1. საკონტაქტო ბლოკები - დამატებულია 'card' კლასი *@
        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="card contact-grid-card shadow-sm border-0">
                    <iconify-icon icon="solar:map-point-bold-duotone" class="contact-icon text-primary"></iconify-icon>
                    <h5 class="fw-bold">მისამართი</h5>
                    <p class="text-muted mb-0">წერეთლის ქუჩა #10, ქუთაისი</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card contact-grid-card shadow-sm border-0">
                    <iconify-icon icon="solar:phone-calling-bold-duotone" class="contact-icon text-success"></iconify-icon>
                    <h5 class="fw-bold">ტელეფონი</h5>
                    <p class="text-muted mb-0">+995 555 12 34 56</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card contact-grid-card shadow-sm border-0">
                    <iconify-icon icon="solar:clock-circle-bold-duotone" class="contact-icon text-warning"></iconify-icon>
                    <h5 class="fw-bold">სამუშაო საათები</h5>
                    <p class="text-muted mb-0">ორშ - კვი: 10:00 - 20:00</p>
                </div>
            </div>
        </div>

        @* 2. რუკა *@
        <div class="row mt-4 mb-5">
            <div class="col-12">
                <div class="map-box shadow-sm">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3023.3323!2d42.70!3d42.26"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // ეს ხაზი აიტანს სქროლს ზემოთ მხოლოდ ამ გვერდზე შემოსვლისას
            await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
            try
            {
                await JsRuntime.InvokeVoidAsync("loadThemeConfig");
                await JsRuntime.InvokeVoidAsync("loadApps");
            }
            catch { }
        }
    }
}