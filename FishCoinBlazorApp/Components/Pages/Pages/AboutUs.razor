@page "/about-us"
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime

<style>
    /* 1. ძირითადი გარემო */
    .main-wrapper {
        min-height: 100vh;
        background-color: var(--bs-body-bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* 2. Hero Section - პრემიუმ მუქი ფონი */
    .about-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        padding: 50px 20px;
        border-radius: 16px;
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* 3. ბარათების სტილი */
    .mission-section {
        border-radius: 15px;
        border: 1px solid rgba(128, 128, 128, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: var(--bs-card-bg);
    }

    .mission-section:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    /* 4. ქვედა CTA ბლოკი */
    .cta-dark {
        background: #1e293b;
        border-radius: 16px;
        padding: 45px 20px;
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .feature-icon {
        width: 50px;
        height: 50px;
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    /* რესპონსივი */
    @@media (max-width: 576px) {
        .about-header h1 {
            font-size: 1.6rem !important;
        }
        .about-header p {
            font-size: 0.95rem !important;
        }
        .cta-dark h3 {
            font-size: 1.4rem;
        }
    }
</style>

<div class="main-wrapper bg-body">
    <Topbar Title="ჩვენს შესახებ" />

    <div class="container-fluid px-3 px-md-4 pt-3">
        <div class="row pb-5">
            <div class="col-12">

                @* 1. Hero Section *@
                <div class="about-header text-center mb-4 mb-md-5 shadow-lg">
                    <h1 class="fw-bold text-white mb-3">
                        პროფესიონალური ეკიპირება <br class="d-none d-md-block" />
                        <span class="text-warning">მონადირეებისა და მეთევზეებისთვის</span>
                    </h1>
                    <p class="text-white opacity-75 mx-auto mb-0" style="max-width: 700px; font-size: 1.05rem; line-height: 1.6;">
                        ჩვენ შევქმენით პლატფორმა, რომელიც აერთიანებს მაღალ ხარისხს, სანდოობასა და ინოვაციურ მიდგომას თქვენი საყვარელი საქმიანობისთვის.
                    </p>
                </div>

                @* 2. Why FishCoin? *@
                <div class="row g-3 g-md-4 mb-5">
                    <div class="col-md-4">
                        <div class="card mission-section h-100 shadow-sm border-0 p-4">
                            <div class="feature-icon">
                                <iconify-icon icon="solar:shield-check-bold" class="fs-2"></iconify-icon>
                            </div>
                            <h5 class="fw-bold">გარანტირებული ხარისხი</h5>
                            <p class="text-muted small mb-0">ჩვენ ვთანამშრომლობთ მხოლოდ ოფიციალურ მომწოდებლებთან, რაც გამორიცხავს არაორიგინალ პროდუქციას.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card mission-section h-100 shadow-sm border-0 p-4">
                            <div class="feature-icon" style="color: #f39c12; background: rgba(243, 156, 18, 0.1);">
                                <iconify-icon icon="solar:delivery-bold" class="fs-2"></iconify-icon>
                            </div>
                            <h5 class="fw-bold">ლოგისტიკა</h5>
                            <p class="text-muted small mb-0">ვზრუნავთ, რომ თქვენი აღჭურვილობა უმოკლეს ვადებში და უსაფრთხოდ მოვიდეს დანიშნულების ადგილამდე.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card mission-section h-100 shadow-sm border-0 p-4">
                            <div class="feature-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.1);">
                                <iconify-icon icon="solar:tag-price-bold" class="fs-2"></iconify-icon>
                            </div>
                            <h5 class="fw-bold">ლოიალობის სისტემა</h5>
                            <p class="text-muted small mb-0">ჩვენ ვაფასებთ თქვენს ნდობას, ამიტომ შევქმენით FishCoin - პროგრამა, რომელიც ყოველ შენაძენს უფრო მომგებიანს ხდის.</p>
                        </div>
                    </div>
                </div>

                @* 3. Approach Section *@
                <div class="row mb-5">
                    <div class="col-12">
                        <div class="p-4 border-start border-warning border-4 bg-body-tertiary rounded-end shadow-sm">
                            <h3 class="fw-bold mb-3">ჩვენი მიდგომა</h3>
                            <p class="text-muted mb-0" style="line-height: 1.8; font-size: 0.95rem;">
                                ბაზარზე შემოსვლის პირველივე დღიდან, ჩვენი პრიორიტეტია მომხმარებლისთვის გამჭვირვალე და კომფორტული გამოცდილების შექმნა. ჩვენ არ ვართ უბრალოდ მაღაზია - ჩვენ ვართ გუნდი, რომელიც თავად არის გატაცებული თევზაობითა და ნადირობით. ზუსტად ვიცით, რამდენად მნიშვნელოვანია თითოეული დეტალი ეკიპირებაში, ამიტომ თითოეულ ნივთს განსაკუთრებული ყურადღებით ვარჩევთ.
                            </p>
                        </div>
                    </div>
                </div>

                @* 4. Call to Action *@
                <div class="cta-dark text-center shadow-lg">
                    <h3 class="fw-bold text-white mb-3">აღმოაჩინე ახალი შესაძლებლობები</h3>
                    <p class="text-white opacity-75 mx-auto mb-4" style="max-width: 600px; font-size: 1rem;">
                        გაეცანით ჩვენს კატალოგს და დაიწყეთ ბონუსების დაგროვება პირველივე შენაძენიდან.
                    </p>

                    <div class="d-flex flex-wrap justify-content-center gap-3">
                        <a href="/products" class="btn btn-light px-4 px-md-5 py-2 fw-bold shadow-sm border-0">
                            <iconify-icon icon="solar:shop-bold" class="me-1 align-middle"></iconify-icon> კატალოგი
                        </a>

                        <a href="/earn-fishcoin" class="btn btn-outline-warning px-4 py-2 fw-bold">
                            როგორ დავაგროვო?
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
                await JsRuntime.InvokeVoidAsync("loadThemeConfig");
                await JsRuntime.InvokeVoidAsync("loadApps");
            }
            catch { }
        }
    }
}