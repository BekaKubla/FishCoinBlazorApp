@page "/about-us"
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime

<style>
    /* Hero Section - პრემიუმ მუქი ფონი, იდეალურია ორივე რეჟიმში */
    .about-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        padding: 50px 20px;
        border-radius: 12px;
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* მისია - ამოღებულია background: #ffffff, დამატებულია card კლასი */
    .mission-section {
        border-radius: 12px;
        padding: 30px;
        transition: transform 0.3s ease;
    }

        .mission-section:hover {
            transform: translateY(-5px);
        }

    /* ქვედა ბლოკი - მუქი რჩება ორივე რეჟიმში (Premium Feel) */
    .cta-dark {
        background: #1e293b;
        border-radius: 12px;
        padding: 40px;
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .feature-icon {
        width: 50px;
        height: 50px;
        background: rgba(30, 58, 138, 0.15);
        color: #3b82f6;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
    }
</style>

<Topbar Title="ჩვენს შესახებ" />

<div class="row pb-5">
    <div class="col-12">

        @* 1. Hero Section *@
        <div class="about-header text-center mb-5 shadow-lg">
            <h1 class="fw-bold text-white mb-3" style="font-size: 2.2rem;">
                პროფესიონალური ეკიპირება <br />
                <span class="text-warning">მონადირეებისა და მეთევზეებისთვის</span>
            </h1>
            <p class="text-white opacity-75 mx-auto mb-0" style="max-width: 700px; font-size: 1.1rem; line-height: 1.6;">
                ჩვენ შევქმენით პლატფორმა, რომელიც აერთიანებს მაღალ ხარისხს, სანდოობასა და ინოვაციურ მიდგომას თქვენი საყვარელი საქმიანობისთვის.
            </p>
        </div>

        @* 2. Why FishCoin? - გამოყენებულია card კლასი ავტომატური Dark Mode-ისთვის *@
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card mission-section h-100 shadow-sm border-0">
                    <div class="feature-icon">
                        <iconify-icon icon="solar:shield-check-bold" class="fs-2"></iconify-icon>
                    </div>
                    <h5 class="fw-bold">გარანტირებული ხარისხი</h5>
                    <p class="text-muted small mb-0">ჩვენ ვთანამშრომლობთ მხოლოდ ოფიციალურ მომწოდებლებთან, რაც გამორიცხავს არაორიგინალ პროდუქციას.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mission-section h-100 shadow-sm border-0">
                    <div class="feature-icon" style="color: #f39c12; background: rgba(243, 156, 18, 0.15);">
                        <iconify-icon icon="solar:delivery-bold" class="fs-2"></iconify-icon>
                    </div>
                    <h5 class="fw-bold">ლოგისტიკა</h5>
                    <p class="text-muted small mb-0">ვზრუნავთ, რომ თქვენი აღჭურვილობა უმოკლეს ვადებში და უსაფრთხოდ მოვიდეს დანიშნულების ადგილამდე.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mission-section h-100 shadow-sm border-0">
                    <div class="feature-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.15);">
                        <iconify-icon icon="solar:tag-price-bold" class="fs-2"></iconify-icon>
                    </div>
                    <h5 class="fw-bold">ლოიალობის სისტემა</h5>
                    <p class="text-muted small mb-0">ჩვენ ვაფასებთ თქვენს ნდობას, ამიტომ შევქმენით FishCoin - პროგრამა, რომელიც ყოველ შენაძენს უფრო მომგებიანს ხდის.</p>
                </div>
            </div>
        </div>

        @* 3. Content Section - bg-body-tertiary იცვლის ფერს თემის მიხედვით *@
        <div class="row align-items-center mb-5">
            <div class="col-lg-12">
                <div class="p-4 border-start border-warning border-4 bg-body-tertiary rounded-end shadow-sm">
                    <h3 class="fw-bold mb-3">ჩვენი მიდგომა</h3>
                    <p class="text-muted mb-0" style="line-height: 1.8;">
                        ბაზარზე შემოსვლის პირველივე დღიდან, ჩვენი პრიორიტეტია მომხმარებლისთვის გამჭვირვალე და კომფორტული გამოცდილების შექმნა. ჩვენ არ ვართ უბრალოდ მაღაზია - ჩვენ ვართ გუნდი, რომელიც თავად არის გატაცებული თევზაობითა და ნადირობით. ზუსტად ვიცით, რამდენად მნიშვნელოვანია თითოეული დეტალი ეკიპირებაში, ამიტომ თითოეულ ნივთს განსაკუთრებული ყურადღებით ვარჩევთ.
                    </p>
                </div>
            </div>
        </div>

        @* 4. Call to Action *@
        <div class="cta-dark text-center shadow-lg">
            <h3 class="fw-bold text-white mb-3">აღმოაჩინე ახალი შესაძლებლობები</h3>
            <p class="text-white opacity-75 mx-auto mb-4" style="max-width: 600px; font-size: 1rem;">
                გაეცანით ჩვენს კატალოგს და დაიწყეთ ბონუსების დაგროვება პირველივე შენაძენიდან.
            </p>

            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a href="/shop" class="btn btn-light px-5 py-2 fw-bold shadow-sm border-0">
                    <iconify-icon icon="solar:shop-bold" class="me-1 align-middle"></iconify-icon> მაღაზია
                </a>

                <a href="/earn-fishcoin" class="btn btn-outline-warning px-4 py-2 fw-bold">
                    როგორ დავაგროვო?
                </a>
            </div>
        </div>

    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // ეს ხაზი აიტანს სქროლს ზემოთ მხოლოდ ამ გვერდზე შემოსვლისას
            await JsRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
            await JsRuntime.InvokeVoidAsync("loadThemeConfig");
            await JsRuntime.InvokeVoidAsync("loadApps");
        }
    }
}