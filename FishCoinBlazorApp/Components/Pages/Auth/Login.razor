@page "/login"
@rendermode InteractiveServer
@using FishCoinBlazorApp.Services.Models
@inject NavigationManager NavManager

<Topbar Title="ავტორიზაცია" />

<div class="auth-wrapper">
    <div class="auth-card border shadow-sm">
        <div class="auth-header py-3">
            <h5 class="fw-bold mb-0">შესვლა</h5>
        </div>

        <div class="auth-body p-4 pt-3">
            @* ყურადღება: აქ ვიყენებთ ჩვეულებრივ EditForm-ს ყოველგვარი POST-ის გარეშე *@
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="auth-label">ტელეფონის ნომერი</label>
                    <InputText @bind-Value="loginModel.PhoneNumber" class="form-control form-control-custom" placeholder="599 00 00 00" />
                    <ValidationMessage For="@(() => loginModel.PhoneNumber)" class="text-danger fs-10" />
                </div>

                <div class="mb-3">
                    <label class="auth-label">პაროლი</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="form-control form-control-custom" placeholder="******" />
                    <ValidationMessage For="@(() => loginModel.Password)" class="text-danger fs-10" />
                </div>

                <div class="mb-4">
                    <label class="fs-13">
                        <InputCheckbox @bind-Value="loginModel.RememberMe" class="form-check-input me-2" /> დამიმახსოვრე
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3">შესვლა</button>
            </EditForm>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 py-2 fs-12 text-center">@errorMessage</div>
            }
        </div>
    </div>
</div>

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 40px;
        min-height: 80vh;
        background-color: var(--bs-body-bg);
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background-color: var(--bs-card-bg);
        border-radius: 16px;
        overflow: hidden;
    }

    .auth-header {
        background-color: var(--bs-tertiary-bg);
        text-align: center;
        border-bottom: 1px solid var(--bs-border-color);
    }

    .auth-label {
        font-size: 10px;
        font-weight: 800;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        margin-bottom: 4px;
        display: block;
    }

    .form-control-custom {
        border-radius: 10px;
        font-size: 14px;
        padding: 10px;
        background-color: var(--bs-body-bg);
        color: var(--bs-body-color);
        border: 1.5px solid #b4bcc7;
        transition: all 0.2s;
    }

        .form-control-custom:focus {
            border-color: var(--bs-primary);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
            outline: none;
        }

    .custom-check {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    [data-bs-theme="dark"] .auth-card {
        background-color: #1a1a1a;
    }

    [data-bs-theme="dark"] .form-control-custom {
        border-color: #444;
    }
</style>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;

    // ვიყენებთ SupplyParameterFromQuery-ს, რომ URL-იდან წამოვიღოთ error-ის სტატუსი
    [SupplyParameterFromQuery]
    public string? error { get; set; }

    protected override void OnInitialized()
    {
        // თუ URL-ში არის error=true, გამოვაჩინოთ შეტყობინება
        if (error == "true")
        {
            errorMessage = "ტელეფონის ნომერი ან პაროლი არასწორია";
        }
    }

    private void HandleLogin()
    {
        errorMessage = null; // გასუფთავება ყოველ დაჭერაზე

        // ვალიდაციის დამატებითი შემოწმება (სურვილისამებრ)
        if (string.IsNullOrEmpty(loginModel.PhoneNumber) || string.IsNullOrEmpty(loginModel.Password))
        {
            errorMessage = "გთხოვთ, შეავსოთ ყველა ველი";
            return;
        }

        var query = $"?phone={loginModel.PhoneNumber}&pass={loginModel.Password}&remember={loginModel.RememberMe}";
        NavManager.NavigateTo($"/Account/DoLogin{query}", forceLoad: true);
    }
}