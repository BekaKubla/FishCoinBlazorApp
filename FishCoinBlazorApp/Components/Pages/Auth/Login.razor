@page "/login"
@rendermode InteractiveServer
@using FishCoinBlazorApp.Services
@using FishCoinBlazorApp.Services.Models
@inject IAccountService AccountService
@inject NavigationManager NavManager
@implements IDisposable

<Topbar Title="ავტორიზაცია" />

<div class="auth-wrapper">
    <div class="auth-card border shadow-sm">
        <div class="auth-header py-3">
            <h5 class="fw-bold mb-0">შესვლა</h5>
        </div>

        <div class="auth-body p-4 pt-3">
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="auth-label">ტელეფონის ნომერი</label>
                    <InputText @bind-Value="loginModel.PhoneNumber" class="form-control form-control-custom" placeholder="599 00 00 00" />
                    <ValidationMessage For="@(() => loginModel.PhoneNumber)" class="text-danger fs-10" />
                </div>

                <div class="mb-3">
                    <label class="auth-label">პაროლი</label>
                    <div class="position-relative">
                        <InputText @bind-Value="loginModel.Password"
                                   type="@(showPassword ? "text" : "password")"
                                   class="form-control form-control-custom"
                                   placeholder="******" />

                        <button type="button"
                                class="btn position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent me-2"
                                @onclick="() => showPassword = !showPassword"
                                style="z-index: 10;">
                            <iconify-icon icon="@(showPassword ? "solar:eye-closed-bold" : "solar:eye-bold")"
                                          class="fs-20 text-secondary align-middle"></iconify-icon>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => loginModel.Password)" class="text-danger fs-10" />
                    <div class="text-end mt-1">
                        <a href="javascript:void(0)" @onclick="OpenResetModal" class="fs-11 text-primary text-decoration-none fw-medium">დაგავიწყდათ პაროლი?</a>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="fs-13 cursor-pointer">
                        <InputCheckbox @bind-Value="loginModel.RememberMe" class="form-check-input me-2" /> დამიმახსოვრე
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3">შესვლა</button>
            </EditForm>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 py-2 fs-12 text-center">@errorMessage</div>
            }
        </div>
    </div>
</div>

@* პაროლის აღდგენის მოდალი *@
@if (isResetModalVisible)
{
    <div class="custom-modal-backdrop">
        <div class="custom-modal-content shadow-lg p-4 text-center">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">პაროლის აღდგენა</h5>
                <button type="button" class="btn-close fs-12" @onclick="() => isResetModalVisible = false"></button>
            </div>

            @if (!isOtpSent)
            {
                <p class="text-muted fs-13">შეიყვანეთ მონაცემები პაროლის შესაცვლელად</p>
                
                <input type="text" @bind="resetPhone" class="form-control form-control-custom mb-2" placeholder="ტელეფონის ნომერი" />
                
                <div class="position-relative mb-2">
                    <input type="@(showResetPass ? "text" : "password")" @bind="newPassword" class="form-control form-control-custom" placeholder="ახალი პაროლი" />
                    <button type="button" class="btn position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent" @onclick="() => showResetPass = !showResetPass">
                        <iconify-icon icon="@(showResetPass ? "solar:eye-closed-bold" : "solar:eye-bold")" class="text-secondary"></iconify-icon>
                    </button>
                </div>

                <input type="@(showResetPass ? "text" : "password")" @bind="confirmPassword" class="form-control form-control-custom mb-3" placeholder="გაიმეორეთ პაროლი" />

                <button @onclick="ProceedToOtp" class="btn btn-primary w-100 py-2 fw-bold" disabled="@isProcessing">
                    @(isProcessing ? "მოწმდება..." : "გაგრძელება")
                </button>
            }
            else
            {
                <div class="mb-3">
                    <iconify-icon icon="solar:smartphone-line-duotone" class="fs-40 text-primary"></iconify-icon>
                </div>
                <p class="text-muted fs-13">SMS კოდი გამოგზავნილია ნომერზე: <br /> <strong>@resetPhone</strong></p>
                <input type="text" @bind="resetOtp" class="form-control form-control-custom mb-3 text-center fs-18 fw-bold" placeholder="0000" maxlength="4" />
                
                <button @onclick="ConfirmReset" class="btn btn-success w-100 py-2 fw-bold" disabled="@isProcessing">
                    @(isProcessing ? "მუშავდება..." : "დადასტურება")
                </button>

                <div class="mt-3">
                    @if (!canResend)
                    {
                        <span class="resend-text">კოდის ხელახლა გაგზავნა: <span class="timer-count">@countdown</span> წამში</span>
                    }
                    else
                    {
                        <button @onclick="ProceedToOtp" class="btn btn-link fs-12 text-decoration-none p-0 text-primary fw-bold">კოდის ხელახლა გაგზავნა</button>
                    }
                </div>
                
                <button @onclick="() => isOtpSent = false" class="btn btn-link fs-12 text-decoration-none mt-2 text-secondary">უკან დაბრუნება</button>
            }

            @if (!string.IsNullOrEmpty(resetError))
            {
                <div class="alert alert-danger mt-3 py-2 fs-11">@resetError</div>
            }
        </div>
    </div>
}

<style>
    .auth-wrapper {
        display: flex; justify-content: center; align-items: flex-start;
        padding-top: 40px; min-height: 80vh; background-color: var(--bs-body-bg);
    }

    .auth-card { width: 100%; max-width: 420px; background-color: var(--bs-card-bg); border-radius: 16px; overflow: hidden; }

    .auth-header { background-color: var(--bs-tertiary-bg); text-align: center; border-bottom: 1px solid var(--bs-border-color); }

    .auth-label { font-size: 10px; font-weight: 800; color: var(--bs-secondary-color); text-transform: uppercase; margin-bottom: 4px; display: block; }

    .form-control-custom {
        border-radius: 10px; font-size: 14px; padding: 10px;
        background-color: var(--bs-body-bg); color: var(--bs-body-color);
        border: 1.5px solid #b4bcc7; transition: all 0.2s;
    }

    .form-control-custom:focus { border-color: var(--bs-primary); box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15); outline: none; }

    .cursor-pointer { cursor: pointer; }

    .custom-modal-backdrop {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: rgba(0, 0, 0, 0.6); display: flex; justify-content: center; align-items: center;
        z-index: 9999; backdrop-filter: blur(4px);
    }

    .custom-modal-content {
        background-color: #ffffff !important; border-radius: 20px;
        width: 90%; max-width: 380px; position: relative; animation: modalAppear 0.3s ease-out;
    }

    [data-bs-theme="dark"] .custom-modal-content { background-color: #1a1a1a !important; }

    .resend-text { font-size: 12px; color: var(--bs-secondary-color); }
    .timer-count { color: var(--bs-primary); font-weight: bold; }

    @@keyframes modalAppear {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    /* Edge-ისთვის */
input::-ms-reveal,
input::-ms-clear {
    display: none;
}

/* Chrome და სხვებისთვის (თუ გამოჩნდა) */
input::-webkit-contacts-auto-fill-button,
input::-webkit-credentials-auto-fill-button {
    visibility: hidden;
    display: none !important;
    pointer-events: none;
}
</style>

@code {
    private bool showPassword;
    private LoginModel loginModel = new();
    private string? errorMessage;

    private bool isResetModalVisible;
    private bool isOtpSent;
    private bool isProcessing;
    private string resetPhone = "";
    private string resetOtp = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string? resetError;
    private bool showResetPass;

    private int countdown = 60;
    private bool canResend = false;
    private System.Threading.Timer? timer;

    [SupplyParameterFromQuery] public string? error { get; set; }

    protected override void OnInitialized()
    {
        if (error == "true") errorMessage = "ტელეფონის ნომერი ან პაროლი არასწორია";
    }

    private void StartTimer()
    {
        countdown = 60;
        canResend = false;
        timer?.Dispose();
        timer = new System.Threading.Timer(_ =>
        {
            if (countdown > 0)
            {
                countdown--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                canResend = true;
                timer?.Dispose();
                InvokeAsync(StateHasChanged);
            }
        }, null, 0, 1000);
    }

    private void OpenResetModal()
    {
        isResetModalVisible = true;
        isOtpSent = false;
        resetError = null;
        resetPhone = "";
        newPassword = "";
        confirmPassword = "";
    }

    private async Task ProceedToOtp()
    {
        resetError = null;

        if (string.IsNullOrEmpty(resetPhone) || string.IsNullOrEmpty(newPassword))
        {
            resetError = "გთხოვთ შეავსოთ ყველა ველი";
            return;
        }
        if (newPassword != confirmPassword)
        {
            resetError = "პაროლები არ ემთხვევა ერთმანეთს";
            return;
        }
        if (newPassword.Length < 6)
        {
            resetError = "პაროლი უნდა იყოს მინიმუმ 6 სიმბოლო";
            return;
        }

        isProcessing = true;
        var existingUser =await AccountService.CheckUserExistsAsync(resetPhone);
        if (!existingUser)
        {
            resetError = "მომხმარებელი ვერ მოიძებნა";
            isProcessing = false;
            return;
        }
        try 
        {
            var result= await AccountService.SendResetOtpAsync(resetPhone);
            if (result.Succeeded)
            {
                isOtpSent = true;
                isProcessing = false;
                StartTimer();
            }
            else
            {
                resetError = result.Errors[0];
            }
        }
        catch{
            resetError = "მოხდა შეცდომა SMS-ის გაგზავნისას. სცადეთ მოგვიანებით.";
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmReset()
    {
        if (string.IsNullOrEmpty(resetOtp)) { resetError = "შეიყვანეთ SMS კოდი"; return; }

        isProcessing = true;
        var result= await AccountService.CompletePasswordResetAsync(resetPhone, resetOtp, newPassword);
        if(result.Succeeded){
            isResetModalVisible = false;
            errorMessage = "პაროლი წარმატებით განახლდა!";
            isProcessing = false;
            var query = $"?phone={resetPhone}&pass={newPassword}&remember=true";
            NavManager.NavigateTo($"/Account/DoLogin{query}", forceLoad: true);
        }
        else
        {
             resetError = result.Errors[0];
             isProcessing = false;
        }
    }

    private void HandleLogin()
    {
        errorMessage = null;
        if (string.IsNullOrEmpty(loginModel.PhoneNumber) || string.IsNullOrEmpty(loginModel.Password))
        {
            errorMessage = "გთხოვთ, შეავსოთ ყველა ველი";
            return;
        }

        var query = $"?phone={loginModel.PhoneNumber}&pass={loginModel.Password}&remember={loginModel.RememberMe}";
        NavManager.NavigateTo($"/Account/DoLogin{query}", forceLoad: true);
    }

    public void Dispose() => timer?.Dispose();
}