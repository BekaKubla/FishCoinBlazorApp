@rendermode InteractiveServer
@inject Services.CartService CartService
@implements IDisposable
@inject IJSRuntime JsRuntime;

<header class="topbar">
    <div class="navbar-header">
        <div class="d-flex align-items-center">
            <!-- Menu Toggle Button -->
            <div class="topbar-item">
                <button type="button" class="button-toggle-menu me-2" @onclick="toggleMenu">
                    <iconify-icon icon="solar:hamburger-menu-broken" class="fs-24 align-middle"></iconify-icon>
                </button>
            </div>

            <!-- Menu Toggle Button -->
            <div class="topbar-item">
                <h4 class="fw-bold topbar-button pe-none text-uppercase mb-0">@Title</h4>
            </div>
        </div>

        <div class="d-flex align-items-center gap-1">
            <!-- Theme Color (Light/Dark) -->
            <div class="topbar-item">
                <button type="button" class="topbar-button" id="light-dark-mode">
                    <iconify-icon icon="solar:moon-bold-duotone" class="fs-24 align-middle"></iconify-icon>
                </button>
            </div>
            <!-- Cart -->
            <div class="dropdown topbar-item">
                <a href="cart" class="topbar-button position-relative d-inline-flex align-items-center">
                    <iconify-icon icon="solar:cart-5-bold-duotone" class="fs-24 align-middle"></iconify-icon>
                    @if (CartService.CartCount > 0)
                    {
                        <span class="position-absolute topbar-badge fs-10 translate-middle badge bg-danger rounded-pill">
                            @CartService.CartCount
                        </span>
                    }
                    </a>
            </div>

            <!-- User -->
            <div class="dropdown topbar-item">
                <a type="button" class="topbar-button" id="page-header-user-dropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <span class="d-flex align-items-center">
                        <img class="rounded-circle" width="32" src="/images/users/avatar-1.jpg" alt="avatar-3">
                    </span>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <!-- item-->
                    <h6 class="dropdown-header">Welcome Gaston!</h6>
                    <a class="dropdown-item" href="pages-profile.html">
                        <i class="bx bx-user-circle text-muted fs-18 align-middle me-1"></i><span class="align-middle">Profile</span>
                    </a>
                    <a class="dropdown-item" href="apps-chat.html">
                        <i class="bx bx-message-dots text-muted fs-18 align-middle me-1"></i><span class="align-middle">Messages</span>
                    </a>

                    <a class="dropdown-item" href="pages-pricing.html">
                        <i class="bx bx-wallet text-muted fs-18 align-middle me-1"></i><span class="align-middle">Pricing</span>
                    </a>
                    <a class="dropdown-item" href="pages-faqs.html">
                        <i class="bx bx-help-circle text-muted fs-18 align-middle me-1"></i><span class="align-middle">Help</span>
                    </a>
                    <a class="dropdown-item" href="auth-lock-screen.html">
                        <i class="bx bx-lock text-muted fs-18 align-middle me-1"></i><span class="align-middle">Lock screen</span>
                    </a>

                    <div class="dropdown-divider my-1"></div>

                    <a class="dropdown-item text-danger" href="auth-signin.html">
                        <i class="bx bx-log-out fs-18 align-middle me-1"></i><span class="align-middle">Logout</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>


@code {
    [Parameter] public required string Title { get; set; }
    private async Task toggleMenu()
    {
        await JsRuntime.InvokeVoidAsync("toggleMenu");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CartService.LoadCart();
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged;
    }
    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }
}