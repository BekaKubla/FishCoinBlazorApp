@rendermode InteractiveServer
@inject Services.CartService CartService
@implements IDisposable
@inject IJSRuntime JsRuntime
@using Microsoft.AspNetCore.Components.Authorization

<header class="topbar">
    <div class="navbar-header">
        <div class="d-flex align-items-center">
            <div class="topbar-item">
                <button type="button" class="button-toggle-menu me-2" @onclick="toggleMenu">
                    <iconify-icon icon="solar:hamburger-menu-broken" class="fs-24 align-middle"></iconify-icon>
                </button>
            </div>

            <div class="topbar-item">
                <h4 class="fw-bold topbar-button pe-none text-uppercase mb-0">@Title</h4>
            </div>
        </div>

        <div class="d-flex align-items-center gap-1">
            <div class="topbar-item">
                <button type="button" class="topbar-button" id="light-dark-mode">
                    <iconify-icon icon="solar:moon-bold-duotone" class="fs-24 align-middle"></iconify-icon>
                </button>
            </div>

            <div class="dropdown topbar-item">
                <a href="cart" class="topbar-button position-relative d-inline-flex align-items-center">
                    <iconify-icon icon="solar:cart-5-bold-duotone" class="fs-24 align-middle"></iconify-icon>
                    @if (CartService.CartCount > 0)
                    {
                        <span class="position-absolute topbar-badge fs-10 translate-middle badge bg-danger rounded-pill">
                            @CartService.CartCount
                        </span>
                    }
                </a>
            </div>

            <div class="dropdown topbar-item">
                <AuthorizeView>
                    <Authorized>
                        @* გამოჩნდება მხოლოდ ავტორიზებული მომხმარებლისთვის *@
                        <a type="button" class="topbar-button" id="page-header-user-dropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="d-flex align-items-center">
                                <img class="rounded-circle" width="32" src="/images/users/avatar-1.jpg" alt="avatar">
                                <span class="ms-2 d-none d-sm-inline-block fw-bold fs-13">@context.User.Identity?.Name</span>
                            </span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end">
                            <h6 class="dropdown-header">მოგესალმებით!</h6>

                            <a class="dropdown-item" href="profile">
                                <i class="bx bx-user-circle text-muted fs-18 align-middle me-1"></i>
                                <span class="align-middle">პროფილი</span>
                            </a>

                            <a class="dropdown-item" href="orders">
                                <i class="bx bx-wallet text-muted fs-18 align-middle me-1"></i>
                                <span class="align-middle">ჩემი შეკვეთები</span>
                            </a>

                            <div class="dropdown-divider my-1"></div>

                            @* Logout ლოგიკა *@
                            <form action="Account/Logout" method="post">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="/" />
                                <button type="submit" class="dropdown-item text-danger w-100 border-0 bg-transparent text-start">
                                    <i class="bx bx-log-out fs-18 align-middle me-1"></i>
                                    <span class="align-middle">გამოსვლა</span>
                                </button>
                            </form>
                        </div>
                    </Authorized>

                    <NotAuthorized>
                        @* Dropdown სტუმრებისთვის *@
                        <div class="dropdown topbar-item">
                            <a type="button" class="topbar-button d-flex align-items-center gap-2"
                                   id="page-header-guest-dropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <iconify-icon icon="solar:user-circle-bold-duotone" class="fs-26 align-middle text-primary"></iconify-icon>
                                <span class="fw-bold fs-13 d-none d-sm-inline-block">ავტორიზაცია</span>
                                <i class="bx bx-chevron-down d-none d-sm-inline-block"></i>
                            </a>
        
                            <div class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <h6 class="dropdown-header text-uppercase fs-11">ანგარიშის მართვა</h6>
            
                                <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="login">
                                    <iconify-icon icon="solar:login-2-linear" class="fs-18 text-muted"></iconify-icon>
                                    <span class="align-middle">შესვლა</span>
                                </a>

                                <a class="dropdown-item d-flex align-items-center gap-2 py-2" href="register">
                                    <iconify-icon icon="solar:user-plus-linear" class="fs-18 text-muted"></iconify-icon>
                                    <span class="align-middle">რეგისტრაცია</span>
                                </a>
                            </div>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</header>
<style>
    /* NotAuthorized მენიუს პოზიციონირება */
    .dropdown-menu-end {
        transform: translate(10px, -5px) !important;
        margin-top: 0 !important;
    }

    #page-header-guest-dropdown + .dropdown-menu {
        right: -5px !important;
        top: 80% !important;
    }
</style>

@code {
    [Parameter] public required string Title { get; set; }

    private async Task toggleMenu()
    {
        await JsRuntime.InvokeVoidAsync("toggleMenu");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CartService.LoadCart();
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }
}