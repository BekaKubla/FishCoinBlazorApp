@using FishCoinBlazorApp.Services
@using FishCoinBlazorApp.Entites.Product.Category
@using Microsoft.AspNetCore.Components.Authorization
@inject CategoryService CategoryService
@inject IJSRuntime JsRuntime
@implements IDisposable
@rendermode InteractiveServer

<div class="main-nav" @ref="mainNavElement">
    <div class="logo-box">
        <a href="/" class="logo-dark">
            <span style="display: flex; align-items: center;margin-left:25px;">
                <span style="display: flex; align-items: center; gap: 6px; font-weight: 800; font-size: 22px; background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: 0.5px; white-space: nowrap;">
                    Fish
                    <iconify-icon icon="game-icons:fishing-pole" style="font-size: 22px; color: #fef08a; flex-shrink: 0; text-shadow: 0 0 8px rgba(254, 240, 138, 0.6);"></iconify-icon>
                    Coin
                    <iconify-icon icon="ph:coin-vertical-duotone" style="font-size: 24px; color: #f59e0b; flex-shrink: 0;"></iconify-icon>
                </span>
            </span>
        </a>

        <a href="/" class="logo-light">
            <span style="display: flex; align-items: center;margin-left:25px;">
                <span style="display: flex; align-items: center; gap: 6px; font-weight: 800; font-size: 22px; color: #ffffff; letter-spacing: 0.5px; white-space: nowrap;">
                    Fish
                    <iconify-icon icon="game-icons:fishing-pole" style="font-size: 22px; color: #fef08a; flex-shrink: 0; text-shadow: 0 0 8px rgba(254, 240, 138, 0.3);"></iconify-icon>
                    Coin
                    <iconify-icon icon="ph:coin-vertical-duotone" style="font-size: 24px; color: #fcd34d; flex-shrink: 0;"></iconify-icon>
                </span>
            </span>
        </a>
    </div>

    <button type="button" class="button-sm-hover" aria-label="Show Full Sidebar" @onclick="ToggleSmHoverMenu">
        <iconify-icon icon="solar:double-alt-arrow-right-bold-duotone" class="button-sm-hover-icon"></iconify-icon>
    </button>

    <div class="scrollbar" data-simplebar>
        <ul class="navbar-nav" id="navbar-nav">
            
            @* --- ადმინ პანელი (ჩანს მხოლოდ Admin როლისთვის) --- *@
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <li class="nav-item">
                        <a class="nav-link menu-arrow" href="#sidebarAdmin" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarAdmin">
                            <span class="nav-icon" style="color: #ef4444;">
                                <iconify-icon icon="solar:shield-user-bold-duotone"></iconify-icon>
                            </span>
                            <span class="nav-text" style="color: #ef4444; font-weight: bold;"> ადმინ პანელი </span>
                        </a>
                        <div class="collapse" id="sidebarAdmin">
                            <ul class="nav sub-navbar-nav">
                                <li class="sub-nav-item">
                                    <a class="sub-nav-link" href="Admin/CreateOrUpdate">პროდუქტის დამატება</a>
                                </li>
                                <li class="sub-nav-item">
                                    <a class="sub-nav-link" href="admin/products">პროდუქტების მართვა</a>
                                </li>
                                <li class="sub-nav-item">
                                    <a class="sub-nav-link" href="admin/orders">შეკვეთები</a>
                                </li>
                            </ul>
                        </div>
                    </li>
                </Authorized>
            </AuthorizeView>

            <li class="nav-item">
                <a class="nav-link" href="/">
                    <span class="nav-icon">
                        <iconify-icon icon="solar:widget-5-bold-duotone"></iconify-icon>
                    </span>
                    <span class="nav-text"> მთავარი </span>
                </a>
            </li>

            @if (categories != null && categories.Any())
            {
                <li class="nav-item">
                    <a class="nav-link menu-arrow" href="#sidebarProducts" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarProducts">
                        <span class="nav-icon">
                            <iconify-icon icon="solar:shop-line-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text"> პროდუქტები </span>
                    </a>
                    <div class="collapse" id="sidebarProducts">
                        <ul class="nav sub-navbar-nav">
                            @foreach (var category in categories)
                            {
                                <li class="sub-nav-item">
                                    <a class="sub-nav-link" href="products?categoryId=@category.Id">@category.CategoryName</a>
                                </li>
                            }
                        </ul>
                    </div>
                </li>
            }

            <li class="nav-item">
                <a class="nav-link menu-arrow" href="#sidebarCategory" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarCategory">
                    <span class="nav-icon">
                        <iconify-icon icon="solar:clipboard-list-bold-duotone"></iconify-icon>
                    </span>
                    <span class="nav-text"> როგორ შევუკვეთო </span>
                </a>
                <div class="collapse" id="sidebarCategory">
                    <ul class="nav sub-navbar-nav">
                        <li class="sub-nav-item">
                            <a class="sub-nav-link" href="category-list">ინსტრუქცია</a>
                        </li>
                        <li class="sub-nav-item">
                            <a class="sub-nav-link" href="category-edit">ვიდეო ინსტრუქცია</a>
                        </li>
                    </ul>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link menu-arrow" href="#sidebarPurchases" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarPurchases">
                    <span class="nav-icon">
                        <iconify-icon icon="ph:coin-vertical-duotone"></iconify-icon>
                    </span>
                    <span class="nav-text"> ქულების სისტემა </span>
                </a>
                <div class="collapse" id="sidebarPurchases">
                    <ul class="nav sub-navbar-nav">
                        <li class="sub-nav-item">
                            <a class="sub-nav-link" href="earn-fishcoin">ქულების გამომუშავება</a>
                        </li>
                        <li class="sub-nav-item">
                            <a class="sub-nav-link" href="spend-fishcoin">ქულების დახარჯვა</a>
                        </li>
                    </ul>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link menu-arrow" href="#sidebarOrders" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarOrders">
                    <span class="nav-icon">
                        <iconify-icon icon="solar:map-line-duotone"></iconify-icon>
                    </span>
                    <span class="nav-text"> ჩვენს შესახებ </span>
                </a>
                <div class="collapse" id="sidebarOrders">
                    <ul class="nav sub-navbar-nav">
                        <li class="sub-nav-item">
                            <a class="sub-nav-link" href="about-us">ვინ ვართ ჩვენ?</a>
                        </li>
                        <li class="sub-nav-item">
                            <a class="sub-nav-link" href="about">მისამართი</a>
                        </li>
                    </ul>
                </div>
            </li>
        </ul>
    </div>
</div>

@code {
    private List<Category> categories;
    private ElementReference mainNavElement;
    private DotNetObjectReference<MainNav>? dotNetRef;

    private async Task ToggleSmHoverMenu()
    {
        await JsRuntime.InvokeVoidAsync("toggleSmHoverMenu");
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("initializeBlazorMenu", mainNavElement, dotNetRef);
        }
    }

    private async Task LoadCategories()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }
}