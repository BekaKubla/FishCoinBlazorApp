<footer class="footer custom-fishcoin-footer">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-12 text-center">
                <p class="footer-content mb-0">
                    @FullYear &copy; <span class="fw-bold text-warning">FishCoin</span>. All Rights Reserved.
                </p>
            </div>
        </div>
    </div>
</footer>
<style>
    .custom-fishcoin-footer {
        /* შენი ახალი ფერი */
        background-color: #262d34 !important;
        /* სისტემური შრიფტები */
        font-family: var(--bs-body-font-family);
        font-size: var(--bs-body-font-size);
        font-weight: var(--bs-body-font-weight);
        line-height: var(--bs-body-line-height);
        /* ტექსტის ფერი */
        color: #adb5bd !important; /* ოდნავ რბილი თეთრი (muted) უკეთესია ამ ფონზე */

        padding: 15px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        width: 100%;
    }

    .text-warning {
        color: #ffc107 !important;
    }

    .footer-content {
        letter-spacing: 0.5px;
    }
</style>

@code {
    public string FullYear = DateTime.Now.Year.ToString();
}